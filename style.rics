ytmusic-carousel-shelf-renderer.ytmusic-section-list-renderer[page-type="MUSIC_PAGE_TYPE_ALBUM"] > .ytmusic-carousel-shelf-renderer > ytmusic-carousel#ytmusic-carousel > #items-wrapper > #items {
