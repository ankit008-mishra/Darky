ytmusic-two-column-browse-results-renderer.ytmusic-browse-response[page-type="MUSIC_PAGE_TYPE_ALBUM"] > #primary.ytmusic-two-column-browse-results-renderer
> ytmusic-section-list-renderer > #contents.ytmusic-section-list-renderer > ytmusic-responsive-header-renderer > 
