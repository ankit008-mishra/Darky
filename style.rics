/* ═══════════════════════════════════════════════════════════════════════
   ANIMATION ENHANCEMENTS — Appended to Darky Theme
   ═══════════════════════════════════════════════════════════════════════ */

/* ── 1. NAVIGATION BAR ANIMATIONS ───────────────────────────────────── */
ytmusic-app-layout > #nav-bar-background {
  animation: animFadeInDown 0.6s cubic-bezier(0.25, 1, 0.5, 1) forwards;
}

ytmusic-nav-bar {
  animation: animFadeInDown 0.5s 0.1s cubic-bezier(0.25, 1, 0.5, 1) both;
}

ytmusic-search-box {
  animation: animFadeIn 0.4s 0.2s cubic-bezier(0.25, 1, 0.5, 1) both;
}

/* Search box focus animation */
ytmusic-search-box[opened] {
  animation: animScaleIn 0.3s cubic-bezier(0.25, 1, 0.5, 1) both;
}

/* ── 2. SIDEBAR ANIMATIONS ──────────────────────────────────────────── */
#guide-wrapper {
  animation: animFadeInLeft 0.6s cubic-bezier(0.25, 1, 0.5, 1) forwards;
}

/* Stagger animation for sidebar items */
ytmusic-guide-entry-renderer tp-yt-paper-item {
  animation: animFadeInLeft 0.4s cubic-bezier(0.25, 1, 0.5, 1) both;
}

ytmusic-guide-entry-renderer:nth-child(1) tp-yt-paper-item { animation-delay: 0.05s; }
ytmusic-guide-entry-renderer:nth-child(2) tp-yt-paper-item { animation-delay: 0.1s; }
ytmusic-guide-entry-renderer:nth-child(3) tp-yt-paper-item { animation-delay: 0.15s; }
ytmusic-guide-entry-renderer:nth-child(4) tp-yt-paper-item { animation-delay: 0.2s; }
ytmusic-guide-entry-renderer:nth-child(5) tp-yt-paper-item { animation-delay: 0.25s; }
ytmusic-guide-entry-renderer:nth-child(6) tp-yt-paper-item { animation-delay: 0.3s; }
ytmusic-guide-entry-renderer:nth-child(7) tp-yt-paper-item { animation-delay: 0.35s; }
ytmusic-guide-entry-renderer:nth-child(8) tp-yt-paper-item { animation-delay: 0.4s; }

/* Sidebar item hover enhancement */
ytmusic-guide-entry-renderer tp-yt-paper-item:hover {
  transform: translateX(8px) scale(1.02) !important;
}

/* Active sidebar item pulse */
ytmusic-guide-entry-renderer[active] tp-yt-paper-item {
  animation: animFadeInLeft 0.4s cubic-bezier(0.25, 1, 0.5, 1) both, animPulse 2s ease-in-out infinite 0.5s;
}

/* ── 3. SEARCH DROPDOWN ANIMATIONS ──────────────────────────────────── */
ytmusic-search-box #suggestion-list {
  transition: opacity 0.3s cubic-bezier(0.2, 0.8, 0.2, 1), 
              transform 0.3s cubic-bezier(0.2, 0.8, 0.2, 1), 
              visibility 0.3s !important;
}

ytmusic-search-box[opened]:has(ytmusic-search-suggestion) #suggestion-list,
ytmusic-search-box[opened]:has(ytmusic-responsive-list-item-renderer) #suggestion-list {
  animation: animSlideDown 0.3s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
}

/* Search suggestion hover */
ytmusic-search-suggestion:hover, 
ytmusic-search-box #suggestion-list ytmusic-responsive-list-item-renderer:hover {
  transform: translateX(6px) !important;
}

/* ── 4. CONTENT CARDS ANIMATIONS ──────────────────────────────────── */
ytmusic-responsive-list-item-renderer,
ytmusic-two-row-item-renderer,
ytmusic-carousel-item-renderer {
  animation: animFadeInUp 0.5s cubic-bezier(0.25, 1, 0.5, 1) both;
}

/* Stagger for grid items */
ytmusic-two-row-item-renderer:nth-child(1) { animation-delay: 0.05s; }
ytmusic-two-row-item-renderer:nth-child(2) { animation-delay: 0.1s; }
ytmusic-two-row-item-renderer:nth-child(3) { animation-delay: 0.15s; }
ytmusic-two-row-item-renderer:nth-child(4) { animation-delay: 0.2s; }
ytmusic-two-row-item-renderer:nth-child(5) { animation-delay: 0.25s; }
ytmusic-two-row-item-renderer:nth-child(6) { animation-delay: 0.3s; }

/* Card hover lift */
ytmusic-two-row-item-renderer:hover,
ytmusic-responsive-list-item-renderer:hover {
  transform: translateY(-4px) !important;
}

/* Thumbnail hover */
ytmusic-two-row-item-renderer yt-img-shadow img,
ytmusic-responsive-list-item-renderer yt-img-shadow img {
  transition: transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1), filter 0.4s ease !important;
}

ytmusic-two-row-item-renderer:hover yt-img-shadow img,
ytmusic-responsive-list-item-renderer:hover yt-img-shadow img {
  transform: scale(1.05) !important;
}

/* ── 5. TOP RESULTS ANIMATIONS ──────────────────────────────────────── */
ytmusic-top-result-item-renderer,
ytmusic-card-shelf-renderer {
  animation: animScaleIn 0.6s cubic-bezier(0.25, 1, 0.5, 1) both;
}

/* Top result hover scale */
ytmusic-top-result-item-renderer:hover yt-img-shadow img,
ytmusic-card-shelf-renderer:hover yt-img-shadow img {
  transform: scale(1.15) !important;
  transition: transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1) !important;
}

/* ── 6. CAROUSEL BUTTONS ANIMATIONS ───────────────────────────────── */
ytmusic-carousel-shelf-basic-header-renderer .yt-spec-button-shape-next--outline {
  animation: animFadeInUp 0.4s cubic-bezier(0.25, 1, 0.5, 1) both;
  transition: all 0.3s cubic-bezier(0.25, 1, 0.5, 1) !important;
}

ytmusic-carousel-shelf-basic-header-renderer .yt-spec-button-shape-next--outline:hover {
  transform: translateY(-2px) scale(1.05) !important;
  box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3) !important;
}

ytmusic-carousel-shelf-renderer yt-icon-button {
  animation: animFadeIn 0.4s cubic-bezier(0.25, 1, 0.5, 1) both;
  transition: all 0.3s cubic-bezier(0.25, 1, 0.5, 1) !important;
}

ytmusic-carousel-shelf-renderer yt-icon-button:hover {
  transform: scale(1.15) rotate(5deg) !important;
}

/* ── 7. TABS ANIMATIONS ─────────────────────────────────────────────── */
ytmusic-tabs,
ytmusic-tabs #tabs.tab-container,
ytmusic-tabbed-search-results-renderer #tabs {
  animation: animFadeInUp 0.5s 0.2s cubic-bezier(0.25, 1, 0.5, 1) both;
}

/* ── 8. ARTIST PAGE ANIMATIONS ──────────────────────────────────────── */
ytmusic-immersive-header-renderer,
ytmusic-data-bound-header-renderer,
ytmusic-visual-header-renderer {
  animation: animFadeIn 0.6s ease forwards;
}

ytmusic-immersive-header-renderer .image,
.image.ytmusic-immersive-header-renderer,
ytmusic-data-bound-header-renderer #background,
ytmusic-visual-header-renderer .image {
  animation: animScaleIn 0.8s ease forwards;
}

/* Header buttons */
ytmusic-immersive-header-renderer .yt-spec-button-shape-next--filled,
ytmusic-subscribe-button-renderer .yt-spec-button-shape-next--outline,
ytmusic-shelf-renderer .yt-spec-button-shape-next--outline,
ytmusic-music-shelf-renderer .yt-spec-button-shape-next--outline {
  animation: animFadeInUp 0.5s 0.3s cubic-bezier(0.25, 1, 0.5, 1) both;
  transition: all 0.3s cubic-bezier(0.25, 1, 0.5, 1) !important;
}

ytmusic-immersive-header-renderer .yt-spec-button-shape-next--filled:hover,
ytmusic-subscribe-button-renderer .yt-spec-button-shape-next--outline:hover,
ytmusic-shelf-renderer .yt-spec-button-shape-next--outline:hover,
ytmusic-music-shelf-renderer .yt-spec-button-shape-next--outline:hover {
  transform: translateY(-2px) scale(1.05) !important;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3) !important;
}

/* ── 9. LYRICS ENGINE ANIMATIONS ────────────────────────────────────── */
/* Background pulse */
ytmusic-player-page:before {
  animation: animBgPulse 8s ease-in-out infinite alternate, animBlurIn 1s ease forwards;
}

/* Lyric line active animation */
.blyrics-container>.blyrics--line.blyrics--active,
.blyrics-container>.blyrics--line.blyrics--animating {
  animation: lyricActive 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
}

@keyframes lyricActive {
  from { transform: scale(0.95) translateX(10px); filter: blur(5px); }
  to { transform: scale(1) translateX(0); filter: blur(0); }
}

/* Word bounce */
.blyrics--line.blyrics--active .blyrics--word.blyrics--animating,
.blyrics--line.blyrics--animating .blyrics--word.blyrics--animating {
  animation: wordBounce 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) forwards !important;
}

@keyframes wordBounce {
  0% { transform: translateY(3px) scale(0.95); opacity: 0.5; }
  60% { transform: translateY(-2px) scale(1.02); }
  100% { transform: translateY(0) scale(1); opacity: 1; }
}

/* Romanized/Translated reveal */
.blyrics--line>.blyrics--romanized,
.blyrics--line>.blyrics--translated {
  animation: smoothReveal 0.5s cubic-bezier(0.2, 0.8, 0.2, 1) backwards;
}

/* Footer animations */
.blyrics-footer__container,
.blyrics-footer__discord {
  animation: animFadeInUp 0.5s cubic-bezier(0.25, 1, 0.5, 1) both;
}

.blyrics-footer__container:hover,
.blyrics-footer__discord:hover {
  transform: translateY(-2px) scale(1.02) !important;
  box-shadow: 0 8px 25px rgba(0, 0, 0, 0.2) !important;
}

/* ── 10. PLAYER BAR ANIMATIONS ──────────────────────────────────────── */
ytmusic-app-layout > [slot="player-bar"] {
  animation: animSlideUp 0.5s cubic-bezier(0.25, 1, 0.5, 1) both;
}

ytmusic-player-bar {
  animation: animSlideUp 0.5s 0.1s cubic-bezier(0.25, 1, 0.5, 1) both;
}

/* Player bar buttons */
ytmusic-player-bar tp-yt-paper-icon-button {
  transition: transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1), background-color 0.2s ease, opacity 0.2s ease !important;
}

ytmusic-player-bar tp-yt-paper-icon-button:hover {
  transform: scale(1.15) !important;
}

ytmusic-player-bar tp-yt-paper-icon-button:active {
  transform: scale(0.85) !important;
  transition: transform 0.1s cubic-bezier(0.45, 0, 0.15, 1) !important;
}

/* Progress bar hover */
ytmusic-player-bar #progress-bar {
  transition: all 0.3s ease !important;
}

ytmusic-player-bar #progress-bar:hover {
  transform: translateX(-50%) scaleY(1.5) !important;
}

/* ── 11. MENU & DROPDOWN ANIMATIONS ─────────────────────────────────── */
/* 3-dot menu */
tp-yt-iron-dropdown:has(ytmusic-menu-popup-renderer),
tp-yt-iron-dropdown:has(ytmusic-multi-page-menu-renderer) {
  animation: animScaleIn 0.25s cubic-bezier(0.34, 1.56, 0.64, 1) forwards !important;
}

/* Menu items */
ytmusic-menu-popup-renderer tp-yt-paper-item.ytmusic-menu-navigation-item-renderer,
ytmusic-menu-popup-renderer tp-yt-paper-item.ytmusic-menu-service-item-renderer {
  transition: all 0.2s ease !important;
}

ytmusic-menu-popup-renderer tp-yt-paper-item.ytmusic-menu-navigation-item-renderer:hover,
ytmusic-menu-popup-renderer tp-yt-paper-item.ytmusic-menu-service-item-renderer:hover {
  transform: translateX(4px) !important;
}

/* Settings modal */
ytmusic-dialog {
  animation: animScaleIn 0.35s cubic-bezier(0.25, 1, 0.5, 1) forwards !important;
}

/* Add to playlist */
tp-yt-paper-dialog:has(ytmusic-add-to-playlist-renderer),
tp-yt-paper-dialog:has(ytmusic-unified-share-panel-renderer) {
  animation: animScaleBounce 0.35s cubic-bezier(0.34, 1.56, 0.64, 1) forwards !important;
}

/* Playlist items hover */
ytmusic-playlist-add-to-option-renderer {
  transition: all 0.2s ease !important;
}

ytmusic-playlist-add-to-option-renderer:hover {
  transform: translateX(6px) !important;
}

/* ── 12. QUEUE ANIMATIONS ───────────────────────────────────────────── */
ytmusic-player-queue-item {
  transition: background-color 0.4s ease, transform 0.2s cubic-bezier(0.45, 0, 0.15, 1) !important;
  animation: animFadeInRight 0.4s cubic-bezier(0.25, 1, 0.5, 1) both;
}

/* Stagger queue items */
ytmusic-player-queue-item:nth-child(1) { animation-delay: 0.02s; }
ytmusic-player-queue-item:nth-child(2) { animation-delay: 0.04s; }
ytmusic-player-queue-item:nth-child(3) { animation-delay: 0.06s; }
ytmusic-player-queue-item:nth-child(4) { animation-delay: 0.08s; }
ytmusic-player-queue-item:nth-child(5) { animation-delay: 0.1s; }

ytmusic-player-queue-item:hover {
  background-color: rgba(255, 255, 255, 0.1) !important;
  transform: translateX(4px) !important;
}

ytmusic-player-queue-item:active {
  transform: scale(0.98) !important;
  background-color: rgba(255, 255, 255, 0.15) !important;
}

ytmusic-player-queue-item yt-img-shadow img {
  transition: transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1), filter 0.4s ease !important;
}

ytmusic-player-queue-item:hover yt-img-shadow img {
  transform: scale(1.15) !important;
  filter: brightness(0.65) !important;
}

/* Queue chips */
ytmusic-player-queue ytmusic-chip-cloud-chip-renderer a.yt-simple-endpoint,
ytmusic-queue-header-renderer ytmusic-chip-cloud-chip-renderer a.yt-simple-endpoint {
  transition: all 0.3s ease !important;
}

ytmusic-player-queue ytmusic-chip-cloud-chip-renderer a.yt-simple-endpoint:hover,
ytmusic-queue-header-renderer ytmusic-chip-cloud-chip-renderer a.yt-simple-endpoint:hover {
  transform: translateY(-2px) scale(1.05) !important;
}

ytmusic-player-queue ytmusic-chip-cloud-chip-renderer a.yt-simple-endpoint:active,
ytmusic-queue-header-renderer ytmusic-chip-cloud-chip-renderer a.yt-simple-endpoint:active {
  transform: scale(0.95) !important;
}

/* ── 13. CHIP CLOUD ANIMATIONS ──────────────────────────────────────── */
ytmusic-chip-cloud-chip-renderer a.yt-simple-endpoint {
  transition: all 0.3s cubic-bezier(0.25, 1, 0.5, 1) !important;
}

ytmusic-chip-cloud-chip-renderer a.yt-simple-endpoint:hover {
  transform: translateY(-2px) scale(1.05) !important;
  box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2) !important;
}

/* ── 14. PLAYER PAGE ANIMATIONS ─────────────────────────────────────── */
/* Miniplayer animations */
ytmusic-player-page[mini-player-enabled][player-page-open] #player.ytmusic-player-page {
  animation: mp-grow 0.75s cubic-bezier(0.3, 0.6, 0.5, 1) !important;
}

ytmusic-player-page[mini-player-enabled]:not([player-page-open]) #player.ytmusic-player-page {
  animation: mp-shrink 1s cubic-bezier(0.5, 0.6, 0.5, 1) !important;
}

@keyframes mp-grow {
  0% { transform: translate3d(60%, 0, 0) scale(0.2); opacity: 0; }
  100% { transform: translate3d(0, 0, 0) scale(1); opacity: 1; }
}

@keyframes mp-shrink {
  0% { transform: scale(1.7); opacity: 0; }
  50% { opacity: 0; }
  100% { transform: translate3d(0, 0, 0) scale(1); opacity: 1; }
}

/* Player panel transitions */
ytmusic-player-page #main-panel.ytmusic-player-page,
ytmusic-player-page #player.ytmusic-player-page,
ytmusic-player-page #side-panel.ytmusic-player-page {
  transition: max-width 0.8s cubic-bezier(0.2, 0.8, 0.2, 1),
              max-height 0.8s cubic-bezier(0.2, 0.8, 0.2, 1),
              min-width 0.8s cubic-bezier(0.2, 0.8, 0.2, 1),
              width 0.8s cubic-bezier(0.2, 0.8, 0.2, 1),
              height 0.8s cubic-bezier(0.2, 0.8, 0.2, 1),
              padding 0.8s cubic-bezier(0.2, 0.8, 0.2, 1),
              transform 0.8s cubic-bezier(0.2, 0.8, 0.2, 1),
              margin 0.8s cubic-bezier(0.2, 0.8, 0.2, 1),
              left 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);
}

/* ── 15. SKELETON/LOADING ANIMATIONS ──────────────────────────────── */
ytmusic-skeleton,
.ytmusic-skeleton {
  background: linear-gradient(90deg, rgba(255,255,255,0.05) 25%, rgba(255,255,255,0.1) 50%, rgba(255,255,255,0.05) 75%) !important;
  background-size: 200% 100% !important;
  animation: animShimmer 1.5s infinite !important;
}

/* ── 16. TOAST NOTIFICATIONS ────────────────────────────────────────── */
tp-yt-paper-toast,
.yt-notification-action-response-overlay {
  animation: animSlideUp 0.4s cubic-bezier(0.25, 1, 0.5, 1) forwards !important;
}

/* ── 17. PLAY BUTTON ANIMATIONS ─────────────────────────────────────── */
ytmusic-play-button-renderer {
  transition: all 0.3s cubic-bezier(0.25, 1, 0.5, 1) !important;
}

ytmusic-play-button-renderer:hover {
  transform: scale(1.1) !important;
  box-shadow: 0 8px 25px rgba(0, 0, 0, 0.4) !important;
}

ytmusic-play-button-renderer:active {
  transform: scale(0.95) !important;
}

/* ── 18. THUMBNAIL OVERLAY ANIMATIONS ───────────────────────────────── */
ytmusic-item-thumbnail-overlay-renderer {
  transition: all 0.3s ease !important;
}

ytmusic-item-thumbnail-overlay-renderer:hover {
  transform: scale(1.02) !important;
}

/* ── 19. VOLUME SLIDER ANIMATION ────────────────────────────────────── */
#volume-slider.ytmusic-player-bar {
  transition: all 0.3s ease !important;
}

#volume-slider.ytmusic-player-bar:hover {
  transform: scaleX(1.05) !important;
}

/* ── 20. LIKE/DISLIKE BUTTON ANIMATIONS ─────────────────────────────── */
#like-button.ytmusic-player-bar,
#dislike-button.ytmusic-player-bar {
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1) !important;
}

#like-button.ytmusic-player-bar:hover,
#dislike-button.ytmusic-player-bar:hover {
  transform: scale(1.2) rotate(-5deg) !important;
}

/* Like button heartbeat when active */
#like-button.ytmusic-player-bar[aria-pressed="true"] {
  animation: animHeartbeat 1.3s ease-in-out infinite;
}
/* =========================================
   ⚙️ THEME CONTROL PANEL (USER CUSTOMIZATION) 
   Easily tweak the values below to personalize the theme!
   ========================================= */
:root {
  /* --- 1. GLASS & BLUR SETTINGS --- */
  --lucid-glass-blur: 25px; /* Master blur amount for the top nav, player bar, and menus */
  
  --lucid-nav-glass-bg: rgba(30, 30, 30, 0); /* Top navigation bar background */
  --lucid-player-glass-bg: rgba(20, 20, 20, 0.2); /* Bottom player bar background */
  
  --lucid-menu-dark-bg: rgba(30, 30, 30, 0.35); /* Settings & Profile menu background */
  --lucid-menu-light-bg: rgba(30, 30, 30, 0.1); /* 3-Dot Song menu background */
  
  /* --- 2. VIDEO TAB MODE (Audio/Video toggle set to Video) --- */
  --lucid-video-tab-gap: 1.3vw; /* Gap between lyrics and video */
  --lucid-video-tab-center: 17.5vw; /* Centering shift when NO lyrics are found */
  
  /* --- 3. AUDIO TAB MODE (Forced video fallback without YT Premium) --- */
  --lucid-audio-tab-forced-video-gap: 1vw; /* Gap between lyrics and forced video */
  --lucid-audio-tab-forced-video-center: 15vw; /* Centering shift when NO lyrics are found */
  
  /* --- 4. AUDIO MODE CENTERING --- */
  --lucid-audio-center: 25vw; /* Centering shift for square album art when NO lyrics are found */

  /* --- 5. BETTERLYRICS NATIVE ENGINE SETTINGS --- */
  --blyrics-lyric-active-color: color(display-p3 1 1 1 / 1);
  --blyrics-lyric-inactive-color: color(display-p3 1 1 1 / 0.2);
  --blyrics-font-family: "MySanFrancisco", "SF Pro", system-ui, "Segoe UI", Roboto, Helvetica, Arial, sans-serif, "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol";
  --blyrics-lyric-scroll-duration: 800ms;
  --blyrics-lyric-scroll-timing-function: cubic-bezier(0.45, 0, 0.15, 1);
  --blyrics-scale-transition-duration: 0.6s;
  --blyrics-scroll-timing-offset: 0.6s;
  --blyrics-background-rotate-speed: 30s;
  
  --blyrics-panel-size: 50%;
  --blyrics-video-panel-size: 37%;
  --blyrics-fullscreen-panel-size: 55%;
  --blyrics-fullscreen-video-panel-size: 36%;
  --blyrics-font-size: 3rem;
  --yt-album-size: 700px;
}

@media (min-width: 1279px) {
  :root {
    --blyrics-font-size: 5rem;
  }
  .blyrics-background-lyric {
    font-size: 0.65em;
  }
}

* {
  font-family: "MySanFrancisco", "SF Pro", system-ui, "Segoe UI", Roboto, Helvetica, Arial, sans-serif, "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol" !important;
}

/* =========================================
   --- 2. GLOBAL UTILITIES & RESETS --- 
   ========================================= */

/* Global Scrollbar Removal */
::-webkit-scrollbar {
  display: none !important;
  width: 0px !important;
  background: transparent !important;
}

* {
  scrollbar-width: none !important;
  -ms-overflow-style: none !important;
}

:root {
  --ytmusic-scrollbar-width: 0px !important;
}

/* Global Button Active States */
tp-yt-paper-icon-button:active, 
yt-button-shape:active,
ytmusic-play-button-renderer:active,
.yt-spec-button-shape-next:active {
  transform: scale(0.92) !important;
  transition: transform 0.1s cubic-bezier(0.45, 0, 0.15, 1) !important;
}

tp-yt-paper-icon-button, 
yt-button-shape,
ytmusic-play-button-renderer,
.yt-spec-button-shape-next {
  transition: transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1), 
              background-color 0.2s ease, 
              opacity 0.2s ease !important;
}

/* =========================================
   --- 3. TOP NAVIGATION & SEARCH --- 
   ========================================= */

/* Extended Glass Navigation Bar */
ytmusic-app-layout > #nav-bar-background {
  background: var(--lucid-nav-glass-bg) !important;
  backdrop-filter: blur(var(--lucid-glass-blur)) !important;
  -webkit-backdrop-filter: blur(var(--lucid-glass-blur)) !important;
  height: 90px !important;
  pointer-events: none !important; 
  -webkit-mask-image: linear-gradient(to bottom, black 54px, transparent 100%) !important;
  mask-image: linear-gradient(to bottom, black 54px, transparent 100%) !important;
  border-bottom: none !important; 
  box-shadow: none !important;
}

ytmusic-app-layout #nav-bar-divider { 
  display: none !important; 
}

ytmusic-nav-bar { 
  background: transparent !important; 
  border: none !important; 
  box-shadow: none !important; 
}

/* Page Loading Progress Bar Elevation */
yt-page-navigation-progress {
  z-index: 9999 !important;
}

/* Search Box Transitions */
ytmusic-search-box, 
ytmusic-search-box .search-box, 
ytmusic-search-box[opened],
ytmusic-search-box[has-query], 
ytmusic-search-box[opened] .search-box, 
ytmusic-search-box[has-query] .search-box {
  transition: width 0.5s cubic-bezier(0.2, 0.8, 0.2, 1), 
              max-width 0.5s cubic-bezier(0.2, 0.8, 0.2, 1),
              min-width 0.5s cubic-bezier(0.2, 0.8, 0.2, 1), 
              background-color 0.3s ease,
              border-color 0.3s ease, 
              box-shadow 0.3s ease !important;
}

/* Search Box Base Wrappers */
ytmusic-search-box, 
ytmusic-search-box[opened], 
ytmusic-search-box[has-query],
ytmusic-search-box .search-container, 
ytmusic-search-box[opened] .search-container,
ytmusic-search-box[has-query] .search-container {
  background: transparent !important; 
  background-color: transparent !important; 
  border: none !important;
  box-shadow: none !important; 
  outline: none !important; 
  backdrop-filter: none !important;
}

/* Search Input Pill (Closed & Hover States) */
ytmusic-search-box .search-box {
  border-radius: 12px !important;
  border: 1px solid rgba(255, 255, 255, 0.1) !important;
  transition: background-color 0.2s ease, border-color 0.2s ease, border-radius 0.2s ease 0.15s !important;
}

ytmusic-search-box:hover .search-box { 
  background: rgba(255, 255, 255, 0.08) !important;
  border-color: rgba(255, 255, 255, 0.2) !important;
}

/* Search Input Pill (Opened State) - SEAMLESS GLASS INTEGRATION */
ytmusic-search-box[opened]:has(ytmusic-search-suggestion) .search-box,
ytmusic-search-box[opened]:has(ytmusic-responsive-list-item-renderer) .search-box {
  background: transparent !important; 
  border-radius: 12px 12px 0 0 !important;
  border-bottom: 1px solid rgba(255, 255, 255, 0.08) !important;
  transition: background-color 0.2s ease, border-color 0.2s ease, border-radius 0.2s ease 0s !important;
}

ytmusic-search-box[opened]:not(:has(ytmusic-search-suggestion)):not(:has(ytmusic-responsive-list-item-renderer)) .search-box {
  background: transparent !important;
  border-radius: 12px !important; 
  border-bottom: 1px solid rgba(255, 255, 255, 0.1) !important;
  transition: background-color 0.2s ease, border-color 0.2s ease, border-radius 0.2s ease 0s !important;
}

/* Search Dropdown List Container */
ytmusic-search-box #suggestion-list {
  background: rgba(25, 25, 25, 0.85) !important;
  border-radius: 0 0 20px 20px !important; 
  border: 1px solid rgba(255, 255, 255, 0.1) !important;
  border-top-color: transparent !important;
  box-shadow: 0 20px 40px rgba(0, 0, 0, 0.7) !important;
  padding: 0 !important; 
  margin-top: 0 !important;
  opacity: 0 !important; 
  visibility: hidden !important;
  transform: scaleY(0.95) !important; 
  transform-origin: top !important; 
  pointer-events: none !important; 
  display: block !important;
  transition: opacity 0.2s cubic-bezier(0.2, 0.8, 0.2, 1), 
              transform 0.2s cubic-bezier(0.2, 0.8, 0.2, 1), 
              visibility 0.2s !important;
}

ytmusic-search-box[opened]:has(ytmusic-search-suggestion) #suggestion-list,
ytmusic-search-box[opened]:has(ytmusic-responsive-list-item-renderer) #suggestion-list {
  opacity: 1 !important; 
  visibility: visible !important;
  transform: scaleY(1) !important; 
  pointer-events: auto !important; 
}

ytmusic-search-box:not(:has(ytmusic-search-suggestion)):not(:has(ytmusic-responsive-list-item-renderer)) #suggestion-list { 
  display: none !important; 
}

ytmusic-search-box #suggestion-list ytmusic-search-suggestions-section {
  background: transparent !important; 
  border: none !important; 
  box-shadow: none !important; 
  padding: 8px 0 !important; 
}

/* Search Text Brightness & Formatting */
ytmusic-search-suggestion .title, 
ytmusic-search-suggestion yt-formatted-string,
ytmusic-search-suggestion yt-formatted-string span, 
ytmusic-search-suggestion yt-icon,
ytmusic-search-suggestion .search-suggestion-icon, 
ytmusic-search-box #suggestion-list ytmusic-responsive-list-item-renderer yt-formatted-string,
ytmusic-search-box #suggestion-list ytmusic-responsive-list-item-renderer yt-formatted-string span, 
ytmusic-search-box #suggestion-list ytmusic-responsive-list-item-renderer yt-formatted-string a {
  color: #ffffff !important; 
  fill: #ffffff !important; 
  opacity: 1 !important; 
  font-weight: 500 !important;
}

ytmusic-search-suggestion, 
ytmusic-search-box #suggestion-list ytmusic-responsive-list-item-renderer {
  background: transparent !important; 
  border-radius: 8px !important; 
  margin: 0 8px !important; 
  transition: background-color 0.2s ease !important;
}

ytmusic-search-suggestion:hover, 
ytmusic-search-suggestion[selected], 
ytmusic-search-box #suggestion-list ytmusic-responsive-list-item-renderer:hover {
  background-color: rgba(255, 255, 255, 0.12) !important;
}

/* =========================================
   --- 4. SIDEBAR NAVIGATION --- 
   ========================================= */

/* Sidebar Base Structure */
#mini-guide-background, 
ytmusic-app-layout #mini-guide-background {
  background: transparent !important; 
  opacity: 0 !important; 
  display: none !important;
}

#guide-wrapper {
  background: rgba(30, 30, 30, 0) !important; 
  backdrop-filter: blur(var(--lucid-glass-blur)) !important; 
  -webkit-backdrop-filter: blur(var(--lucid-glass-blur)) !important;
  border-right: 1px solid rgba(255, 255, 255, 0.1) !important;
}

tp-yt-app-drawer, 
tp-yt-app-drawer #contentContainer, 
ytmusic-guide-renderer, 
#guide-content,
#mini-guide, 
#mini-guide-spacer, 
ytmusic-app-layout[guide-persistent-and-visible] #guide-wrapper {
  background: transparent !important; 
  background-color: transparent !important;
}

ytmusic-guide-renderer { 
  border-right: none !important; 
}

/* Expanded Sidebar Items */
ytmusic-guide-entry-renderer tp-yt-paper-item {
  border-radius: 12px !important; 
  margin: 0 8px !important; 
  transition: background-color 0.2s ease !important;
}

ytmusic-guide-entry-renderer:hover tp-yt-paper-item { 
  background: rgba(255, 255, 255, 0.1) !important; 
}

ytmusic-guide-entry-renderer[active] tp-yt-paper-item { 
  background: rgba(255, 255, 255, 0.15) !important; 
}

/* Mini Sidebar Layout Fix */
ytmusic-guide-entry-renderer[is-collapsed] tp-yt-paper-item {
  border-radius: 12px !important; 
  width: calc(100% - 8px) !important; 
  margin: 0 auto !important; 
  box-sizing: border-box !important; 
  transition: background-color 0.2s ease !important;
}

/* New Playlist Button */
.yt-spec-button-shape-next--mono.yt-spec-button-shape-next--tonal {
  background: rgba(255, 255, 255, 0.1) !important; 
  color: #ffffff !important; 
  border: 1px solid rgba(255, 255, 255, 0.1) !important;
  border-radius: 16px !important; 
  transition: background-color 0.2s ease !important;
}

.yt-spec-button-shape-next--mono.yt-spec-button-shape-next--tonal:hover { 
  background: rgba(255, 255, 255, 0.2) !important; 
}

/* =========================================
   --- 5. HOME PAGE & CONTENT --- 
   ========================================= */

/* Mood Filter Chips */
ytmusic-chip-cloud-renderer ytmusic-chip-cloud-chip-renderer { 
  background: transparent !important; 
}

ytmusic-chip-cloud-renderer ytmusic-chip-cloud-chip-renderer a.yt-simple-endpoint {
  background: rgba(255, 255, 255, 0.08) !important; 
  backdrop-filter: blur(12px) !important;
  border: 1px solid rgba(255, 255, 255, 0.05) !important; 
  border-radius: 30px !important;
  transition: all 0.3s ease !important; 
  color: #ffffff !important; 
  height: 36px !important; 
  padding: 0 6px !important;
  display: flex !important; 
  align-items: center !important;
}

ytmusic-chip-cloud-renderer ytmusic-chip-cloud-chip-renderer a.yt-simple-endpoint:hover { 
  background: rgba(255, 255, 255, 0.15) !important; 
}

ytmusic-chip-cloud-renderer ytmusic-chip-cloud-chip-renderer[is-selected] a.yt-simple-endpoint { 
  background: #ffffff !important; 
  color: #000000 !important; 
  font-weight: 600 !important; 
}

/* Filter Chip Scrolling & Masking */
ytmusic-chip-cloud-renderer {
  -webkit-mask-image: linear-gradient(to right, black 0%, black 92%, transparent 100%) !important;
  mask-image: linear-gradient(to right, black 0%, black 92%, transparent 100%) !important;
}

ytmusic-chip-cloud-renderer #chips {
  overflow-x: auto !important; 
  scroll-behavior: smooth !important; 
  padding: 4px 24px 4px 0 !important; 
}

/* Home Page Album Effects */
ytmusic-two-row-item-renderer ytmusic-thumbnail-renderer #image { 
  overflow: hidden !important; 
}

ytmusic-two-row-item-renderer ytmusic-thumbnail-renderer #image img { 
  transition: transform 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) !important; 
}

ytmusic-two-row-item-renderer:hover ytmusic-thumbnail-renderer #image img { 
  transform: scale(1.06) !important; 
}

ytmusic-two-row-item-renderer ytmusic-thumbnail-renderer { 
  box-shadow: none !important; 
  transition: box-shadow 0.4s ease !important; 
}

ytmusic-two-row-item-renderer:hover ytmusic-thumbnail-renderer { 
  box-shadow: 0 16px 32px rgba(0,0,0,0.5) !important; 
}

/* Apply 12px squircle to Home Page grid, strictly excluding Circular Artists */
ytmusic-two-row-item-renderer:not([aspect-ratio="MUSIC_TWO_ROW_ITEM_THUMBNAIL_ASPECT_RATIO_CIRCLE"]):not(:has([thumbnail-crop="MUSIC_THUMBNAIL_CROP_CIRCLE"])) .image-wrapper,
ytmusic-two-row-item-renderer:not([aspect-ratio="MUSIC_TWO_ROW_ITEM_THUMBNAIL_ASPECT_RATIO_CIRCLE"]):not(:has([thumbnail-crop="MUSIC_THUMBNAIL_CROP_CIRCLE"])) yt-img-shadow,
ytmusic-two-row-item-renderer:not([aspect-ratio="MUSIC_TWO_ROW_ITEM_THUMBNAIL_ASPECT_RATIO_CIRCLE"]):not(:has([thumbnail-crop="MUSIC_THUMBNAIL_CROP_CIRCLE"])) .thumbnail-overlay { 
  border-radius: 12px !important; 
  overflow: hidden !important;
}

/* Apply 10px squircle to Quick Picks, strictly excluding Circular Artists */
ytmusic-responsive-list-item-renderer:not(:has([thumbnail-crop="MUSIC_THUMBNAIL_CROP_CIRCLE"])):not([music-item-style="MUSIC_ITEM_STYLE_ARTIST"]) yt-img-shadow, 
ytmusic-responsive-list-item-renderer:not(:has([thumbnail-crop="MUSIC_THUMBNAIL_CROP_CIRCLE"])):not([music-item-style="MUSIC_ITEM_STYLE_ARTIST"]) yt-img-shadow img { 
  border-radius: 10px !important; 
  overflow: hidden !important;
}

ytmusic-responsive-list-item-renderer yt-img-shadow img { 
  transition: filter 0.3s ease, transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1) !important;
}

/* ALWAYS scale up on hover (Songs, Videos, AND Artists) */
ytmusic-responsive-list-item-renderer:hover yt-img-shadow img {
  transform: scale(1.15) !important;
}

/* ONLY darken if it is NOT a circular artist image */
ytmusic-responsive-list-item-renderer:not(:has([thumbnail-crop="MUSIC_THUMBNAIL_CROP_CIRCLE"])):hover yt-img-shadow img, 
ytmusic-responsive-list-item-renderer:not(:has([thumbnail-crop="MUSIC_THUMBNAIL_CROP_CIRCLE"]))[play-button-state="playing"] yt-img-shadow img,
ytmusic-responsive-list-item-renderer:not(:has([thumbnail-crop="MUSIC_THUMBNAIL_CROP_CIRCLE"]))[play-button-state="paused"] yt-img-shadow img { 
  filter: brightness(0.4) !important;
}

/* Remove Native Overlays */
ytmusic-two-row-item-renderer ytmusic-item-thumbnail-overlay-renderer #background, 
ytmusic-two-row-item-renderer ytmusic-background-overlay-renderer,
ytmusic-responsive-list-item-renderer ytmusic-item-thumbnail-overlay-renderer #background, 
ytmusic-responsive-list-item-renderer ytmusic-background-overlay-renderer {
  display: none !important; 
  opacity: 0 !important; 
  background: transparent !important;
}

ytmusic-responsive-list-item-renderer ytmusic-item-thumbnail-overlay-renderer { 
  background: transparent !important; 
}

ytmusic-responsive-list-item-renderer tp-yt-paper-ripple { 
  border-radius: 10px !important; 
}

/* ================================
      TOP SEARCH RESULT OVERLAYS
   ================================ */

/* 1. Remove the native square background overlays on top results */
ytmusic-card-shelf-renderer ytmusic-item-thumbnail-overlay-renderer #background,
ytmusic-card-shelf-renderer ytmusic-background-overlay-renderer,
ytmusic-top-result-item-renderer ytmusic-item-thumbnail-overlay-renderer #background,
ytmusic-top-result-item-renderer ytmusic-background-overlay-renderer {
  display: none !important;
  opacity: 0 !important;
  background: transparent !important;
}

/* 2. Strip background from the overlay container itself */
ytmusic-card-shelf-renderer ytmusic-item-thumbnail-overlay-renderer,
ytmusic-top-result-item-renderer ytmusic-item-thumbnail-overlay-renderer {
  background: transparent !important;
}

/* 3. Apply your custom border-radius and smooth transitions */
ytmusic-card-shelf-renderer yt-img-shadow,
ytmusic-card-shelf-renderer yt-img-shadow img,
ytmusic-top-result-item-renderer yt-img-shadow,
ytmusic-top-result-item-renderer yt-img-shadow img {
  border-radius: 10px !important;
  overflow: hidden !important;
}

ytmusic-card-shelf-renderer yt-img-shadow img,
ytmusic-top-result-item-renderer yt-img-shadow img {
  /* Added transform transition */
  transition: filter 0.3s ease, transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1) !important;
}

/* 4. SCALE EFFECT: Top Results (Applies to EVERYTHING, including artists) */
ytmusic-top-result-item-renderer:not(:has(ytmusic-responsive-list-item-renderer:hover)):has(ytmusic-item-thumbnail-overlay-renderer:hover, yt-img-shadow:hover, #thumbnail:hover, .title:hover, #buttons:hover, .buttons:hover) yt-img-shadow:not(ytmusic-responsive-list-item-renderer yt-img-shadow) img,
ytmusic-card-shelf-renderer:not(:has(ytmusic-responsive-list-item-renderer:hover)):has(ytmusic-item-thumbnail-overlay-renderer:hover, yt-img-shadow:hover, #thumbnail:hover, .title:hover, #buttons:hover, .buttons:hover) yt-img-shadow:not(ytmusic-responsive-list-item-renderer yt-img-shadow) img {
  transform: scale(1.15) !important; 
}

/* 5. DARKEN EFFECT: Top Results (Ignores artists via circular crop check) */
ytmusic-top-result-item-renderer:not(:has([thumbnail-crop="MUSIC_THUMBNAIL_CROP_CIRCLE"])):not(:has(ytmusic-responsive-list-item-renderer:hover)):has(ytmusic-item-thumbnail-overlay-renderer:hover, yt-img-shadow:hover, #thumbnail:hover, .title:hover, #buttons:hover, .buttons:hover) yt-img-shadow:not(ytmusic-responsive-list-item-renderer yt-img-shadow) img,
ytmusic-card-shelf-renderer:not(:has([thumbnail-crop="MUSIC_THUMBNAIL_CROP_CIRCLE"])):not(:has(ytmusic-responsive-list-item-renderer:hover)):has(ytmusic-item-thumbnail-overlay-renderer:hover, yt-img-shadow:hover, #thumbnail:hover, .title:hover, #buttons:hover, .buttons:hover) yt-img-shadow:not(ytmusic-responsive-list-item-renderer yt-img-shadow) img,

ytmusic-top-result-item-renderer:not(:has([thumbnail-crop="MUSIC_THUMBNAIL_CROP_CIRCLE"]))[play-button-state="playing"] yt-img-shadow:not(ytmusic-responsive-list-item-renderer yt-img-shadow) img,
ytmusic-top-result-item-renderer:not(:has([thumbnail-crop="MUSIC_THUMBNAIL_CROP_CIRCLE"]))[play-button-state="paused"] yt-img-shadow:not(ytmusic-responsive-list-item-renderer yt-img-shadow) img,
ytmusic-card-shelf-renderer:not(:has([thumbnail-crop="MUSIC_THUMBNAIL_CROP_CIRCLE"]))[play-button-state="playing"] yt-img-shadow:not(ytmusic-responsive-list-item-renderer yt-img-shadow) img,
ytmusic-card-shelf-renderer:not(:has([thumbnail-crop="MUSIC_THUMBNAIL_CROP_CIRCLE"]))[play-button-state="paused"] yt-img-shadow:not(ytmusic-responsive-list-item-renderer yt-img-shadow) img {
  filter: brightness(0.4) !important;
}

/* Carousel Buttons (Play All, Arrows) */
ytmusic-carousel-shelf-basic-header-renderer .yt-spec-button-shape-next--outline {
  background: rgba(255, 255, 255, 0.08) !important; 
  backdrop-filter: blur(12px) !important;
  border: 1px solid rgba(255, 255, 255, 0.05) !important; 
  border-radius: 30px !important; 
  color: #ffffff !important;
  transition: all 0.3s ease !important; 
  padding: 0px 20px !important; 
}

ytmusic-carousel-shelf-basic-header-renderer .yt-spec-button-shape-next--outline:hover { 
  background: rgba(255, 255, 255, 0.15) !important; 
}

ytmusic-carousel-shelf-renderer yt-icon-button {
  background: rgba(255, 255, 255, 0.08) !important; 
  backdrop-filter: blur(12px) !important;
  border: 1px solid rgba(255, 255, 255, 0.05) !important; 
  border-radius: 50% !important; 
  transition: all 0.3s ease !important;
}

ytmusic-carousel-shelf-renderer yt-icon-button:hover { 
  background: rgba(255, 255, 255, 0.15) !important; 
}

ytmusic-carousel-shelf-renderer yt-icon-button yt-icon { 
  fill: #ffffff !important; 
  color: #ffffff !important; 
}

ytmusic-carousel-shelf-renderer yt-icon-button .circular.yt-interaction { 
  display: none !important; 
}

/* Section Tabs (Phantom Glass Styling) */
ytmusic-tabs, 
ytmusic-tabs #tabs.tab-container, 
ytmusic-tabbed-search-results-renderer #tabs {
  background: transparent !important; 
  background-color: transparent !important; 
  box-shadow: none !important; 
  border: none !important;
}

ytmusic-tabs.stuck::before {
  content: ""; 
  position: absolute !important; 
  top: -30px !important; 
  bottom: -24px !important; 
  left: 0; 
  right: 0;
  background: rgba(30, 30, 30, 0) !important; 
  backdrop-filter: blur(var(--lucid-glass-blur)) !important; 
  -webkit-backdrop-filter: blur(var(--lucid-glass-blur)) !important;
  -webkit-mask-image: linear-gradient(to bottom, black 65%, transparent 100%) !important;
  mask-image: linear-gradient(to bottom, black 65%, transparent 100%) !important; 
  z-index: -1 !important; 
  pointer-events: none !important;
}

ytmusic-app-layout[player-page-open] ytmusic-tabs.stuck::before { 
  display: none !important; 
}

/* =========================================
   --- 6. ARTIST & CHANNEL PAGES --- 
   ========================================= */

/* Dynamic Color Background Header */
ytmusic-immersive-header-renderer, 
ytmusic-immersive-header-renderer#header, 
ytmusic-data-bound-header-renderer,
ytmusic-editable-profile-header-renderer, 
ytmusic-visual-header-renderer {
  background: var(--ytmusic-app) !important;
}

/* Remove Vignette Gradients */
.ytmusic-browse-response .content-container-wrapper, 
.content-container-wrapper .gradient-container,
ytmusic-visual-header-renderer[has-banner-image] .gradient-container.ytmusic-visual-header-renderer {
  background: transparent !important;
}

/* Seamless Image Dissolve Masking */
ytmusic-immersive-header-renderer .image, 
.image.ytmusic-immersive-header-renderer, 
ytmusic-data-bound-header-renderer #background,
ytmusic-data-bound-header-renderer .background, 
ytmusic-data-bound-header-renderer yt-img-shadow, 
ytmusic-editable-profile-header-renderer #background,
ytmusic-editable-profile-header-renderer .background, 
ytmusic-editable-profile-header-renderer yt-img-shadow, 
.image.ytmusic-visual-header-renderer {
  -webkit-mask-image: linear-gradient(to bottom, black 60%, transparent 100%) !important; 
  mask-image: linear-gradient(to bottom, black 60%, transparent 100%) !important;
  -webkit-mask-repeat: no-repeat !important; 
  mask-repeat: no-repeat !important; 
  -webkit-mask-size: 100% !important; 
  mask-size: 100% !important;
  opacity: 0.8 !important; 
  filter: brightness(0.95);
}

ytmusic-immersive-header-renderer .description { 
  transition: max-height 0.6s ease-in-out !important; 
}

/* Header Glass Buttons */
ytmusic-immersive-header-renderer .yt-spec-button-shape-next--filled, 
ytmusic-subscribe-button-renderer .yt-spec-button-shape-next--outline,
ytmusic-shelf-renderer .yt-spec-button-shape-next--outline, 
ytmusic-music-shelf-renderer .yt-spec-button-shape-next--outline {
  background: rgba(255, 255, 255, 0.1) !important; 
  color: #ffffff !important; 
  backdrop-filter: blur(12px) !important;
  -webkit-backdrop-filter: blur(12px) !important; 
  border: 1px solid rgba(255, 255, 255, 0.1) !important; 
  border-radius: 16px !important;
  transition: background-color 0.2s ease !important;
}

ytmusic-immersive-header-renderer .yt-spec-button-shape-next--filled:hover, 
ytmusic-subscribe-button-renderer .yt-spec-button-shape-next--outline:hover,
ytmusic-shelf-renderer .yt-spec-button-shape-next--outline:hover, 
ytmusic-music-shelf-renderer .yt-spec-button-shape-next--outline:hover {
  background: rgba(255, 255, 255, 0.2) !important;
}

ytmusic-subscribe-button-renderer { 
  --ytmusic-subscribe-button-outline-color: transparent !important; 
  --ytmusic-subscribe-button-color: #ffffff !important; 
}


/* =========================================
   --- 8. PLAYER LAYOUT & SIZING --- 
   ========================================= */

/* Panel Master Transitions */
ytmusic-player-page #main-panel.ytmusic-player-page, 
ytmusic-player-page #player.ytmusic-player-page, 
ytmusic-player-page #side-panel.ytmusic-player-page {
  transition: max-width 0.8s cubic-bezier(0.2, 0.8, 0.2, 1), 
              max-height 0.8s cubic-bezier(0.2, 0.8, 0.2, 1), 
              min-width 0.8s cubic-bezier(0.2, 0.8, 0.2, 1), 
              width 0.8s cubic-bezier(0.2, 0.8, 0.2, 1), 
              height 0.8s cubic-bezier(0.2, 0.8, 0.2, 1), 
              padding 0.8s cubic-bezier(0.2, 0.8, 0.2, 1), 
              transform 0.8s cubic-bezier(0.2, 0.8, 0.2, 1), 
              margin 0.8s cubic-bezier(0.2, 0.8, 0.2, 1), 
              left 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);
}

ytmusic-player-page { 
  transition: transform 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) !important; 
}

ytmusic-player-page[player-fullscreened] #main-panel { 
  transition: transform 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) !important; 
}

/* Global Media Sizing */
ytmusic-player-page #player.ytmusic-player-page { 
  border-radius: 12px !important; 
  overflow: hidden !important; 
  box-shadow: 0 8px 30px rgba(0,0,0,0.5) !important; 
  background: transparent !important; 
}

#song-media-window { 
  border-radius: 12px !important; 
}

ytmusic-player-page[player-fullscreened] #song-media-window, 
ytmusic-player-page[player-ui-state="FULLSCREEN"] #song-media-window { 
  background: transparent !important; 
}

ytmusic-player-page[video-mode] .html5-video-container, 
ytmusic-player-page[video-mode] video.html5-main-video { 
  width: 100% !important; 
  height: 100% !important; 
  top: 0 !important; 
  left: 0 !important; 
  object-fit: contain !important; 
}

/* AUDIO MODE: Fullscreen */
ytmusic-player-page:not([video-mode]):not([is-video-truncation-fix-enabled])[player-fullscreened]:not([blyrics-dfs]) #main-panel.ytmusic-player-page { 
  flex-direction: column; 
}

ytmusic-player-page:not([video-mode]):not([is-video-truncation-fix-enabled])[player-fullscreened]:not([blyrics-dfs]) #player.ytmusic-player-page { 
  width: 100% !important;
  max-width: 55vh !important;
  aspect-ratio: 1 !important;
  height: auto !important; 
  max-height: none !important; 
  border-radius: 16px !important; 
  box-shadow: 0 20px 50px rgba(0,0,0,0.4) !important; 
}

ytmusic-player-page[player-fullscreened]:not([video-mode]):not([blyrics-video-mode]):not([blyrics-dfs]):has(.blyrics-container[data-no-lyrics="true"]) #main-panel { 
  transform: translateX(var(--lucid-audio-center)) !important; 
  transition-delay: 1.4s !important; 
}


/* VIDEO TAB MODE (Native YouTube Music) */
ytmusic-player-page[video-mode][player-fullscreened]:not([blyrics-dfs]) #player.ytmusic-player-page { 
  height: auto !important; 
  width: 60vw !important; 
  min-width: 60vw !important; 
  max-width: 60vw !important; 
  flex-shrink: 0 !important; 
  aspect-ratio: 1.7778 !important;
  border-radius: 12px !important; 
  margin-top: 7vh !important; 
}

ytmusic-player-page[video-mode][player-fullscreened]:not([blyrics-dfs]) #main-panel.ytmusic-player-page { 
  padding-right: 0vw !important; 
}

ytmusic-player-page[video-mode][player-fullscreened]:not([blyrics-dfs]) #side-panel.ytmusic-player-page { 
  margin-top: 5vh !important; 
}

ytmusic-player-page[player-fullscreened][blyrics-video-mode]:not([blyrics-dfs]) #main-panel.ytmusic-player-page { 
  padding-right: var(--lucid-video-tab-gap) !important; 
}

ytmusic-player-page[player-fullscreened][blyrics-video-mode]:not([blyrics-dfs]):has(.blyrics-container[data-no-lyrics="true"]) #main-panel { 
  transform: translateX(var(--lucid-video-tab-center)) !important; 
  transition-delay: 1.4s !important; 
}

/* AUDIO TAB MODE (Forced video fallback without YT Premium) */
ytmusic-player-page[video-mode] .side-panel.ytmusic-player-page { 
  margin: 0 0 0 calc(var(--ytmusic-player-page-content-gap) / 2) !important; 
}

ytmusic-player-page:not([is-mweb-modernization-enabled]):not([blyrics-video-mode])[video-mode] #side-panel { 
  width: var(--blyrics-video-panel-size) !important; 
}

ytmusic-player-page:not([blyrics-video-mode])[video-mode][player-fullscreened] #side-panel.ytmusic-player-page { 
  width: var(--blyrics-fullscreen-video-panel-size) !important; 
  margin-top: 0vh !important; 
}

ytmusic-player-page:not([blyrics-video-mode])[video-mode][player-fullscreened]:not([blyrics-dfs]) #player.ytmusic-player-page { 
  margin-top: 1vh !important; 
  transform: translateX(0vw) !important; 
}

ytmusic-player-page[player-fullscreened][video-mode]:not([blyrics-video-mode]):not([blyrics-dfs]) #main-panel.ytmusic-player-page { 
  padding-right: var(--lucid-audio-tab-forced-video-gap) !important; 
}

ytmusic-player-page[player-fullscreened][video-mode]:not([blyrics-video-mode]):not([blyrics-dfs]):has(.blyrics-container[data-no-lyrics="true"]) #main-panel { 
  transform: translateX(var(--lucid-audio-tab-forced-video-center)) !important; 
  transition-delay: 1.4s !important; 
}

/* Miniplayer Animations */
ytmusic-player-page[mini-player-enabled][player-page-open] #player.ytmusic-player-page { 
  animation: mp-grow 0.75s cubic-bezier(0.3, 0.6, 0.5, 1) !important; 
}

ytmusic-player-page[mini-player-enabled]:not([player-page-open]) #player.ytmusic-player-page { 
  animation: mp-shrink 1s cubic-bezier(0.5, 0.6, 0.5, 1) !important; 
}

@keyframes mp-grow { 
  0% { transform: translate3d(60%, 0, 0) scale(0.2); opacity: 0; } 
  100% { transform: translate3d(0, 0, 0) scale(1); opacity: 1; } 
}

@keyframes mp-shrink { 
  0% { transform: scale(1.7); opacity: 0; } 
  50% { opacity: 0; } 
  100% { transform: translate3d(0, 0, 0) scale(1); opacity: 1; } 
}


/* =========================================
   --- 9. BOTTOM PLAYER BAR --- 
   ========================================= */

/* Base Player Bar Container */
ytmusic-app-layout > [slot="player-bar"] { 
  background: transparent !important; 
}

ytmusic-player-bar { 
  background: var(--lucid-player-glass-bg) !important; 
  backdrop-filter: blur(var(--lucid-glass-blur)) !important; 
  transition: background-color 0.4s ease 0.3s, border-top 0.4s ease 0.3s !important; 
}

#player-bar-background, 
ytmusic-player-bar .background-gradient { 
  background: transparent !important; 
  backdrop-filter: none !important; 
  display: none !important; 
}

ytmusic-player-bar, 
ytmusic-player-bar.ytmusic-app { 
  transition: opacity .3s cubic-bezier(.2, 0, .6, 1), 
              transform .3s cubic-bezier(.2, 0, .6, 1), 
              bottom .3s cubic-bezier(.2, 0, .6, 1), 
              background-color .3s cubic-bezier(.2, 0, .6, 1) !important; 
  will-change: opacity, transform, background-color; 
}

/* Hover Effects */
ytmusic-player-bar tp-yt-paper-icon-button { 
  transition: transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1), background-color 0.2s ease, opacity 0.2s ease !important; 
}

ytmusic-player-bar tp-yt-paper-icon-button:active { 
  transform: scale(0.85) !important; 
  transition: transform 0.1s cubic-bezier(0.45, 0, 0.15, 1) !important; 
}

/* Progress Slider Repositioning */
ytmusic-player-bar #progress-bar { 
  position: absolute !important; 
  top: -8px !important; 
  left: 50% !important; 
  transform: translateX(-50%) !important; 
  width: 100% !important; 
  height: 8px !important; 
  padding: 0 !important; 
  --paper-slider-height: 8px !important; 
  z-index: 10; 
}

ytmusic-player-bar #progress-bar #sliderContainer, 
ytmusic-player-bar #progress-bar .bar-container { 
  height: 8px !important; 
  margin: 0 !important; 
  padding: 0 !important; 
  top: 0 !important; 
  bottom: 0 !important; 
  left: 0 !important; 
  right: 0 !important; 
}

ytmusic-player-bar #progress-bar #sliderBar { 
  padding: 0 !important; 
  height: 8px !important; 
  --paper-progress-height: 8px !important; 
  background-color: transparent !important; 
}

ytmusic-player-bar #progress-bar #progressContainer, 
ytmusic-player-bar #progress-bar #primaryProgress, 
ytmusic-player-bar #progress-bar #secondaryProgress { 
  border-radius: 60px !important; 
  height: 8px !important; 
}

ytmusic-player-bar #progress-bar #progressContainer { 
  overflow: hidden; 
  background-color: rgba(255, 255, 255, 0.15) !important; 
}

ytmusic-player-bar #primaryProgress, 
ytmusic-player-bar #primaryProgress.tp-yt-paper-progress { 
  background: #ffffff !important; 
  --paper-progress-active-color: #ffffff !important; 
}

ytmusic-player-bar #progress-bar #sliderKnob { 
  visibility: hidden !important; 
  display: none !important; 
}


/* =========================================
   --- 10. MENUS & SETTINGS (GLASS UI) --- 
   ========================================= */

/* Context Menus (3-Dot Menus & Profile) */
tp-yt-iron-dropdown:has(ytmusic-multi-page-menu-renderer) { 
  background: var(--lucid-menu-dark-bg) !important; 
  backdrop-filter: blur(var(--lucid-glass-blur)) !important; 
  -webkit-backdrop-filter: blur(var(--lucid-glass-blur)) !important; 
  border: 1px solid rgba(255, 255, 255, 0.1) !important; 
  border-radius: 16px !important; 
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5) !important; 
}

tp-yt-iron-dropdown:has(ytmusic-menu-popup-renderer) { 
  background: var(--lucid-menu-light-bg) !important; 
  backdrop-filter: blur(var(--lucid-glass-blur)) !important; 
  -webkit-backdrop-filter: blur(var(--lucid-glass-blur)) !important; 
  border: 1px solid rgba(255, 255, 255, 0.1) !important; 
  border-radius: 16px !important; 
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5) !important; 
}

ytmusic-menu-popup-renderer { 
  background: rgba(255, 255, 255, 0) !important; 
  backdrop-filter: blur(var(--lucid-glass-blur)) !important; 
  border-radius: 12px !important; 
  box-shadow: 0 16px 32px rgba(0, 0, 0, 0.2) !important; 
  border: 1px solid rgba(255, 255, 255, 0.1) !important; 
  padding: 8px 0 !important; 
}

ytmusic-menu-popup-renderer tp-yt-paper-listbox#items { 
  background: transparent !important; 
  border: none !important; 
  padding: 0 !important; 
}

ytmusic-multi-page-menu, 
ytmusic-multi-page-menu-renderer, 
ytd-active-account-header-renderer, 
ytd-multi-page-menu-renderer, 
ytmusic-menu-popup-renderer, 
tp-yt-paper-listbox, 
.ytmusicMultiPageMenuRendererHost, 
.ytmusicMultiPageMenuRendererHeader, 
.ytmusicMultiPageMenuRendererMenuContainer { 
  background: transparent !important; 
  background-color: transparent !important; 
}

/* Context Menu Items */
ytmusic-menu-popup-renderer tp-yt-paper-item.ytmusic-menu-navigation-item-renderer, 
ytmusic-menu-popup-renderer tp-yt-paper-item.ytmusic-menu-service-item-renderer { 
  color: #ffffff !important; 
  font-family: var(--blyrics-font-family) !important; 
  font-weight: 500 !important; 
  font-size: 13px !important; 
  line-height: 1.2 !important; 
  padding: 8px 16px !important; 
  min-height: 40px !important; 
}

ytmusic-menu-popup-renderer tp-yt-paper-item yt-icon:first-of-type { 
  width: 20px !important; 
  min-width: 20px !important; 
  height: 20px !important; 
  --iron-icon-height: 20px !important; 
  --iron-icon-width: 20px !important; 
  fill: #ffffff !important; 
  color: #ffffff !important; 
  margin-right: 14px !important; 
}

ytmusic-menu-popup-renderer tp-yt-paper-item yt-icon:not(:first-of-type) { 
  margin-right: 0 !important; 
}

ytmusic-menu-popup-renderer tp-yt-paper-item.ytmusic-menu-navigation-item-renderer:hover, 
ytmusic-menu-popup-renderer tp-yt-paper-item.ytmusic-menu-service-item-renderer:hover { 
  background-color: rgba(255, 255, 255, 0.15) !important; 
  border-radius: 8px !important; 
  margin: 0 6px !important; 
  transition: background-color 0.2s ease !important; 
}

ytmusic-menu-popup-renderer yt-menu-separator-renderer { 
  border-top: 1px solid rgba(255, 255, 255, 0.1) !important; 
  margin: 4px 16px !important; 
}

tp-yt-paper-item:hover, 
ytd-compact-link-renderer:hover { 
  background: rgba(255, 255, 255, 0.1) !important; 
  border-radius: 12px !important; 
}

tp-yt-iron-dropdown::-webkit-scrollbar, 
tp-yt-iron-dropdown *::-webkit-scrollbar { 
  display: none !important; 
  width: 0 !important; 
}

tp-yt-iron-dropdown, 
tp-yt-iron-dropdown * { 
  scrollbar-width: none !important; 
}

/* Settings Modal */
ytmusic-dialog { 
  background: rgba(30, 30, 30, 0.65) !important; 
  backdrop-filter: blur(var(--lucid-glass-blur)) !important; 
  -webkit-backdrop-filter: blur(var(--lucid-glass-blur)) !important; 
  border: 1px solid rgba(255, 255, 255, 0.1) !important; 
  border-radius: 24px !important; 
  box-shadow: 0 20px 40px rgba(0, 0, 0, 0.6) !important; 
}

ytmusic-settings-page, 
.top-bar.ytmusic-settings-page, 
.content.ytmusic-settings-page, 
tp-yt-paper-listbox.category-menu, 
ytmusic-setting-category-collection-renderer, 
.items.ytmusic-setting-category-collection-renderer { 
  background: transparent !important; 
  background-color: transparent !important; 
  border-bottom: none !important; 
}

ytmusic-setting-category-collection-renderer.ytmusic-settings-page { 
  border-left: 1px solid rgba(255, 255, 255, 0.1) !important; 
}

.category-menu-item.ytmusic-settings-page { 
  border-radius: 12px !important; 
  transition: background-color 0.2s ease !important; 
  margin: 0 12px 4px 12px !important; 
}

.category-menu-item.ytmusic-settings-page:hover { 
  background: rgba(255, 255, 255, 0.1) !important; 
}

.category-menu-item.iron-selected.ytmusic-settings-page { 
  background: rgba(255, 255, 255, 0.15) !important; 
}

/* =========================================
   --- TOAST NOTIFICATIONS (ALERTS) --- 
   ========================================= */

/* The Main Toast Container */
tp-yt-paper-toast {
  --paper-toast-background-color: transparent !important;
  background: var(--lucid-menu-dark-bg) !important;
  backdrop-filter: blur(var(--lucid-glass-blur)) !important;
  -webkit-backdrop-filter: blur(var(--lucid-glass-blur)) !important;
  border: 1px solid rgba(255, 255, 255, 0.1) !important;
  border-radius: 12px !important;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5) !important;
  margin-bottom: 20px !important; 
}

/* Base Text */
tp-yt-paper-toast,
tp-yt-paper-toast #label,
tp-yt-paper-toast yt-formatted-string {
  color: #ffffff !important;
  font-family: var(--blyrics-font-family) !important;
  font-weight: 500 !important;
}

tp-yt-paper-toast .action-button,
tp-yt-paper-toast yt-button-renderer,
tp-yt-paper-toast yt-button-shape {
  background: transparent !important;
  border: none !important;
  padding: 0 !important;
  margin: 0 !important;
}

/* Apply the glass pill ONLY to the lowest-level clickable surfaces */
tp-yt-paper-toast .yt-spec-button-shape-next,
tp-yt-paper-toast paper-button {
  background: rgba(255, 255, 255, 0.1) !important;
  border: 1px solid rgba(255, 255, 255, 0.1) !important;
  border-radius: 16px !important;
  padding: 8px 16px !important;
  margin-left: 12px !important; /* Pushes it away from the toast text */
  transition: background-color 0.2s ease, transform 0.1s cubic-bezier(0.45, 0, 0.15, 1) !important;
}

/* Force the inner text to be bright white, overriding YTM's default blue */
tp-yt-paper-toast .yt-spec-button-shape-next *,
tp-yt-paper-toast paper-button * {
  color: #ffffff !important;
  font-weight: 600 !important;
  text-transform: none !important; /* Stops YTM from forcing ALL CAPS on older buttons */
}

/* Hover & Active States */
tp-yt-paper-toast .yt-spec-button-shape-next:hover,
tp-yt-paper-toast paper-button:hover {
  background: rgba(255, 255, 255, 0.2) !important;
}

tp-yt-paper-toast .yt-spec-button-shape-next:active,
tp-yt-paper-toast paper-button:active {
  transform: scale(0.92) !important;
}

/* =========================================
   --- MODALS & DIALOGS (ALL POP-UPS) --- 
   ========================================= */

/* 1. Target the master Polymer dialog shell that wraps ALL these specific menus */
tp-yt-paper-dialog:has(ytmusic-add-to-playlist-renderer),
tp-yt-paper-dialog:has(ytmusic-unified-share-panel-renderer),
tp-yt-paper-dialog:has(ytmusic-playlist-form),
tp-yt-paper-dialog:has(ytmusic-confirm-dialog-renderer),
tp-yt-paper-dialog:has(yt-confirm-dialog-renderer),
tp-yt-paper-dialog:has(yt-dialog-view-model),
tp-yt-paper-dialog:has(ytmusic-dismissable-dialog-renderer), /* <-- View Song Credits */
tp-yt-paper-dialog:has(yt-report-form-modal-renderer)        /* <-- Report UI */ {
  --paper-dialog-background-color: transparent !important;
  background: rgba(30, 30, 30, 0.4) !important;
  
  backdrop-filter: blur(var(--lucid-glass-blur)) !important;
  -webkit-backdrop-filter: blur(var(--lucid-glass-blur)) !important;
  border: 1px solid rgba(255, 255, 255, 0.1) !important;
  border-radius: 24px !important;
  box-shadow: 0 20px 40px rgba(0, 0, 0, 0.6) !important;
}

/* 2. Strip the secondary backgrounds off the inner content wrappers */
ytmusic-add-to-playlist-renderer,
.title-bar.ytmusic-add-to-playlist-renderer,
#playlists.ytmusic-add-to-playlist-renderer,
ytmusic-unified-share-panel-renderer,
#header.ytmusic-unified-share-panel-renderer,
#contents.ytmusic-unified-share-panel-renderer,
yt-any-copy-link-renderer,
ytmusic-playlist-form,
.header.ytmusic-playlist-form,
#actions.ytmusic-playlist-form,
ytmusic-confirm-dialog-renderer,
yt-confirm-dialog-renderer,
tp-yt-paper-dialog-scrollable,
yt-dialog-view-model, 
dialog-layout,
ytmusic-dismissable-dialog-renderer,         /* <-- Song Credits Inner */
.top-bar.ytmusic-dismissable-dialog-renderer,
ytmusic-multi-row-list-item-renderer,
yt-report-form-modal-renderer,               /* <-- Report UI Inner */
yt-report-form-modal-content,
.buttons.yt-report-form-modal-renderer {
  background: transparent !important;
  background-color: transparent !important;
  border: none !important;
  box-shadow: none !important;
}

/* 3. Add to Playlist: Hover states for individual playlists */
ytmusic-playlist-add-to-option-renderer {
  border-radius: 12px !important;
  transition: background-color 0.2s ease !important;
  margin: 0 8px !important;
}

ytmusic-playlist-add-to-option-renderer:hover {
  background: rgba(255, 255, 255, 0.1) !important;
}

/* 4. Share Menu: Style the 'Copy Link' box */
#copy-link.yt-any-copy-link-renderer {
  background: rgba(255, 255, 255, 0.08) !important;
  border: 1px solid rgba(255, 255, 255, 0.1) !important;
  border-radius: 12px !important;
}

/* 5. Share Menu: Hover states for apps/socials */
yt-share-target-renderer {
  border-radius: 12px !important;
  transition: background-color 0.2s ease !important;
}

yt-share-target-renderer:hover {
  background: rgba(255, 255, 255, 0.1) !important;
}

/* =========================================
   --- 11. UP NEXT QUEUE --- 
   ========================================= */

/* Queue Header & Filters */
ytmusic-player-queue ytmusic-chip-cloud-chip-renderer, 
ytmusic-queue-header-renderer ytmusic-chip-cloud-chip-renderer { 
  background: transparent !important; 
}

ytmusic-player-queue ytmusic-chip-cloud-chip-renderer a.yt-simple-endpoint, 
ytmusic-queue-header-renderer ytmusic-chip-cloud-chip-renderer a.yt-simple-endpoint { 
  background: rgba(255, 255, 255, 0.1) !important; 
  backdrop-filter: blur(16px) !important; 
  border: 1px solid rgba(255, 255, 255, 0.08) !important; 
  border-radius: 30px !important; 
  box-shadow: none !important; 
  transition: all 0.3s ease !important; 
  height: 36px !important; 
  display: flex !important; 
  align-items: center !important; 
  justify-content: center !important; 
}

ytmusic-player-queue ytmusic-chip-cloud-chip-renderer a.yt-simple-endpoint { 
  padding: 0 4px !important; 
}

ytmusic-queue-header-renderer ytmusic-chip-cloud-chip-renderer a.yt-simple-endpoint { 
  padding: 0 10px !important; 
}

ytmusic-player-queue ytmusic-chip-cloud-chip-renderer yt-icon, 
ytmusic-player-queue ytmusic-chip-cloud-chip-renderer yt-formatted-string, 
ytmusic-player-queue ytmusic-chip-cloud-chip-renderer svg, 
ytmusic-queue-header-renderer ytmusic-chip-cloud-chip-renderer yt-icon, 
ytmusic-queue-header-renderer ytmusic-chip-cloud-chip-renderer yt-formatted-string, 
ytmusic-queue-header-renderer ytmusic-chip-cloud-chip-renderer svg { 
  fill: #ffffff !important; 
  color: #ffffff !important; 
  transition: all 0.3s ease !important; 
}

ytmusic-player-queue ytmusic-chip-cloud-chip-renderer[is-selected] a.yt-simple-endpoint, 
ytmusic-player-queue ytmusic-chip-cloud-chip-renderer[chip-style="STYLE_PRIMARY"] a.yt-simple-endpoint, 
ytmusic-queue-header-renderer ytmusic-chip-cloud-chip-renderer[is-selected] a.yt-simple-endpoint, 
ytmusic-queue-header-renderer ytmusic-chip-cloud-chip-renderer[chip-style="STYLE_PRIMARY"] a.yt-simple-endpoint { 
  background: rgba(255, 255, 255, 0.9) !important; 
  border-color: rgba(255, 255, 255, 1) !important; 
}

ytmusic-player-queue ytmusic-chip-cloud-chip-renderer[is-selected] yt-formatted-string, 
ytmusic-player-queue ytmusic-chip-cloud-chip-renderer[chip-style="STYLE_PRIMARY"] yt-formatted-string, 
ytmusic-player-queue ytmusic-chip-cloud-chip-renderer[is-selected] yt-icon, 
ytmusic-player-queue ytmusic-chip-cloud-chip-renderer[chip-style="STYLE_PRIMARY"] yt-icon, 
ytmusic-queue-header-renderer ytmusic-chip-cloud-chip-renderer[is-selected] yt-formatted-string, 
ytmusic-queue-header-renderer ytmusic-chip-cloud-chip-renderer[chip-style="STYLE_PRIMARY"] yt-formatted-string, 
ytmusic-queue-header-renderer ytmusic-chip-cloud-chip-renderer[is-selected] yt-icon, 
ytmusic-queue-header-renderer ytmusic-chip-cloud-chip-renderer[chip-style="STYLE_PRIMARY"] yt-icon { 
  color: #000000 !important; 
  fill: #000000 !important; 
  font-weight: 600 !important; 
}

ytmusic-player-queue ytmusic-chip-cloud-chip-renderer a.yt-simple-endpoint:hover, 
ytmusic-queue-header-renderer ytmusic-chip-cloud-chip-renderer a.yt-simple-endpoint:hover { 
  background: rgba(255, 255, 255, 0.2) !important; 
  border-color: rgba(255, 255, 255, 0.15) !important; 
}

ytmusic-player-queue ytmusic-chip-cloud-chip-renderer[is-selected] a.yt-simple-endpoint:hover, 
ytmusic-player-queue ytmusic-chip-cloud-chip-renderer[chip-style="STYLE_PRIMARY"] a.yt-simple-endpoint:hover, 
ytmusic-queue-header-renderer ytmusic-chip-cloud-chip-renderer[is-selected] a.yt-simple-endpoint:hover, 
ytmusic-queue-header-renderer ytmusic-chip-cloud-chip-renderer[chip-style="STYLE_PRIMARY"] a.yt-simple-endpoint:hover { 
  background: rgba(255, 255, 255, 1) !important; 
}

ytmusic-player-queue ytmusic-chip-cloud-chip-renderer a.yt-simple-endpoint:active, 
ytmusic-queue-header-renderer ytmusic-chip-cloud-chip-renderer a.yt-simple-endpoint:active { 
  transform: scale(0.95) !important; 
}

ytmusic-chip-cloud-renderer #chips::-webkit-scrollbar { 
  height: 4px !important; 
}

ytmusic-chip-cloud-renderer #chips::-webkit-scrollbar-track { 
  background: transparent !important; 
}

ytmusic-chip-cloud-renderer #chips::-webkit-scrollbar-thumb { 
  background-color: transparent !important; 
  border-radius: 10px !important; 
}

ytmusic-chip-cloud-renderer:hover #chips::-webkit-scrollbar-thumb { 
  background-color: rgba(255, 255, 255, 0.3) !important; 
}

ytmusic-chip-cloud-renderer #chips { 
  scrollbar-width: thin !important; 
  scrollbar-color: transparent transparent !important; 
}

ytmusic-chip-cloud-renderer:hover #chips { 
  scrollbar-color: rgba(255, 255, 255, 0.3) transparent !important; 
}

ytmusic-chip-cloud-renderer { 
  margin-bottom: -8px !important; 
}

/* Queue Row Items */
ytmusic-player-queue-item { 
  --ytmusic-player-queue-item-thumbnail-size: 40px !important; 
  border-radius: 8px !important; 
  margin: 1px 8px !important; 
  padding: 4px 8px !important; 
  border-bottom: none !important; 
  transition: background-color 0.4s ease, transform 0.1s cubic-bezier(0.45, 0, 0.15, 1) !important; 
}

ytmusic-player-queue-item:hover { 
  background-color: rgba(255, 255, 255, 0.1) !important; 
  transform: none !important; 
}

ytmusic-player-queue-item:active { 
  transform: scale(0.98) !important; 
  background-color: rgba(255, 255, 255, 0.15) !important; 
}

ytmusic-player-queue-item[selected] { 
  background-color: rgba(255, 255, 255, 0.08) !important; 
}

ytmusic-player-queue-item yt-img-shadow { 
  border-radius: 6px !important; 
  overflow: hidden !important; 
}

ytmusic-player-queue-item yt-img-shadow img { 
  transition: transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1), filter 0.4s ease !important; 
}

ytmusic-player-queue-item:hover yt-img-shadow img { 
  transform: scale(1.15) !important; 
  filter: brightness(0.65) !important; 
}

ytmusic-player-queue-item[selected]:hover yt-img-shadow img { 
  filter: brightness(1) !important; 
}

ytmusic-player-queue-item ytmusic-item-thumbnail-overlay-renderer, 
ytmusic-player-queue-item ytmusic-thumbnail-overlay-renderer { 
  background: transparent !important; 
}

ytmusic-player-queue-item ytmusic-item-thumbnail-overlay-renderer > #background, 
ytmusic-player-queue-item ytmusic-thumbnail-overlay-renderer > #background, 
ytmusic-player-queue-item ytmusic-play-button-renderer > #background { 
  display: none !important; 
}

ytmusic-player-queue-item ytmusic-play-button-renderer { 
  background: transparent !important; 
  opacity: 0 !important; 
  transition: opacity 0.4s ease !important; 
}

ytmusic-player-queue-item:hover ytmusic-play-button-renderer, 
ytmusic-player-queue-item[selected] ytmusic-play-button-renderer { 
  opacity: 1 !important; 
}

/* =========================================
   LUCID THEME: SEAMLESS SEARCH DROPDOWN
   ========================================= */

/* Z-index fix for navbar */
ytmusic-app-layout:not([player-ui-state="PLAYER_PAGE_OPEN"]) #nav-bar-background {
  z-index: 4 !important;
}

/* STEP 1: Make the original dropdown transparent and set it as an Anchor */
ytmusic-search-box[is-bauhaus-sidenav-enabled] {
  --ytmusic-search-background: transparent !important;
}

ytmusic-search-box[is-bauhaus-sidenav-enabled] #suggestion-list.ytmusic-search-box {
  background: transparent !important;
  box-shadow: none !important;
  border: none !important;
  anchor-name: --search-dropdown; 
}

/* STEP 2: The Lucid Frosted Glass Layer */
ytmusic-app-layout::after {
  content: "";
  position: fixed; 
  position-anchor: --search-dropdown;      
  top: calc(anchor(top) - 40px) !important;              
  left: anchor(left) !important;            
  width: calc(anchor-size(width) - 2px) !important;    
  height: calc(anchor-size(height) + 38px) !important;  
  
  /* --- LUCID GLASS STYLING (NOW VARIABLE-BOUND) --- */
  backdrop-filter: blur(var(--lucid-glass-blur));
  -webkit-backdrop-filter: blur(var(--lucid-glass-blur));
  background: var(--lucid-menu-dark-bg);  
  border-radius: 12px; 
  border: 1px solid rgba(255, 255, 255, 0.08); 
  box-shadow: 0 12px 40px rgba(0, 0, 0, 0.4); 
  /* --------------------------- */
  
  z-index: 4 !important;
  pointer-events: none; 

  /* Smooth fade-out transition */
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.25s cubic-bezier(0.2, 0.8, 0.2, 1), visibility 0.25s !important;
}

/* STEP 3: Active State Trigger */
ytmusic-app-layout:has(ytmusic-search-box:focus-within)::after,
ytmusic-app-layout:has(ytmusic-search-box[opened])::after {
  opacity: 1;
  visibility: visible;
  /* Instant, snappy appear */
  transition: opacity 0.1s ease-out, visibility 0.1s !important; 
}

/* =========================================
   LUCID GLOBAL POLISH: VIDEOS & MAIN BUTTONS
   ========================================= */

/* 1. Force 16:9 Video Thumbnails to have rounded corners */
ytmusic-top-result-item-renderer yt-img-shadow,
ytmusic-responsive-list-item-renderer yt-img-shadow,
ytmusic-card-shelf-renderer yt-img-shadow {
    border-radius: 1px !important;
    overflow: hidden !important;
    -webkit-mask-image: -webkit-radial-gradient(white, black) !important;
}

ytmusic-top-result-item-renderer yt-img-shadow img,
ytmusic-responsive-list-item-renderer yt-img-shadow img,
ytmusic-card-shelf-renderer yt-img-shadow img {
    border-radius: 1px !important;
    height: auto !important; 
    max-height: 100% !important; 
}

/* 2. OVERRIDE: Protect Playlists and Albums from the 16:9 shrink */
ytmusic-responsive-list-item-renderer[music-item-style="MUSIC_ITEM_STYLE_PLAYLIST"] yt-img-shadow img,
ytmusic-responsive-list-item-renderer[music-item-style="MUSIC_ITEM_STYLE_ALBUM"] yt-img-shadow img {
    height: 100% !important; /* Forces 1:1 square items to stay square */
}

/* 3. OVERRIDE: Protect Artists (Restore Perfect Circles across all pages) */
[thumbnail-crop="MUSIC_THUMBNAIL_CROP_CIRCLE"] yt-img-shadow,
[thumbnail-crop="MUSIC_THUMBNAIL_CROP_CIRCLE"] yt-img-shadow img,
ytmusic-responsive-list-item-renderer:has([thumbnail-crop="MUSIC_THUMBNAIL_CROP_CIRCLE"]) yt-img-shadow,
ytmusic-responsive-list-item-renderer:has([thumbnail-crop="MUSIC_THUMBNAIL_CROP_CIRCLE"]) yt-img-shadow img {
    border-radius: 50% !important;
    -webkit-mask-image: none !important;
    height: 100% !important; /* Reverts the height auto */
}

/* 4. Style the Main "Play" and "Save" Action Buttons on Top Results (Your Exact Code) */
ytmusic-top-result-item-renderer .yt-spec-button-shape-next--filled,
ytmusic-card-shelf-renderer .yt-spec-button-shape-next--filled {
    background: rgba(255, 255, 255, 0.15) !important;
    backdrop-filter: blur(12px) !important;
    -webkit-backdrop-filter: blur(12px) !important; 
    border: 1px solid rgba(255, 255, 255, 0.25) !important; 
    border-radius: 24px !important;
    transition: all 0.2s ease !important;
}

ytmusic-top-result-item-renderer .yt-spec-button-shape-next--outline,
ytmusic-top-result-item-renderer .yt-spec-button-shape-next--tonal,
ytmusic-card-shelf-renderer .yt-spec-button-shape-next--outline,
ytmusic-card-shelf-renderer .yt-spec-button-shape-next--tonal {
    background: rgba(255, 255, 255, 0.05) !important;
    backdrop-filter: blur(12px) !important;
    -webkit-backdrop-filter: blur(12px) !important; 
    border: 1px solid rgba(255, 255, 255, 0.1) !important; 
    border-radius: 24px !important;
    transition: all 0.2s ease !important;
}

ytmusic-top-result-item-renderer .yt-spec-button-shape-next--filled *,
ytmusic-card-shelf-renderer .yt-spec-button-shape-next--filled * {
    color: #ffffff !important;
    fill: #ffffff !important;
}

ytmusic-top-result-item-renderer .yt-spec-button-shape-next--filled:hover,
ytmusic-card-shelf-renderer .yt-spec-button-shape-next--filled:hover {
    background: rgba(255, 255, 255, 0.25) !important;
}

ytmusic-top-result-item-renderer .yt-spec-button-shape-next--outline:hover,
ytmusic-top-result-item-renderer .yt-spec-button-shape-next--tonal:hover,
ytmusic-card-shelf-renderer .yt-spec-button-shape-next--outline:hover,
ytmusic-card-shelf-renderer .yt-spec-button-shape-next--tonal:hover {
    background: rgba(255, 255, 255, 0.15) !important;
}

/* =========================================
   CANARY PATCH: FIX "NO LYRICS" OVERFLOW & FOOTER ALIGNMENT
   ========================================= */

/* 1. Strip the massive dynamic padding and center the "No Lyrics" text */
.blyrics-container[data-no-lyrics="true"] {
    display: flex !important;
    flex-direction: column !important;
    justify-content: center !important;
    align-items: center !important; /* Keeps the text centered horizontally */
    height: 100% !important;
    padding-bottom: 2rem !important;
    position: relative !important; /* Creates an anchor point for the footer */
}

/* 2. Break the footer out of the center and pin it to the bottom */
.blyrics-container[data-no-lyrics="true"] .blyrics-footer,
.blyrics-container[data-no-lyrics="true"] .blyrics-footer__container {
    position: absolute !important;
    bottom: 2rem !important; /* Pushes it near the bottom edge */
    left: 50% !important;
    transform: translateX(-50%) !important; /* Centers the buttons horizontally */
    width: max-content !important;
}

/* =========================================
   CANARY PATCH V4: FINAL UNISON & DISCORD FIXES
   ========================================= */

/* 1. Force the Submitter Card to perfectly center itself below the buttons */
.blyrics-footer__unison {
    width: 100% !important; 
    flex-basis: 100% !important; 
    display: flex !important;
    justify-content: center !important; 
    margin-top: 4px !important; 
}

/* 2. Apply the premium Lucid Glass specifically to the Unison Cards */
.blyrics-footer__unison-card,
.blyrics-unison-dock__inner {
    background: rgba(255, 255, 255, 0.05) !important; 
    backdrop-filter: blur(16px) !important; 
    -webkit-backdrop-filter: blur(16px) !important;
    border: 1px solid rgba(255, 255, 255, 0.08) !important; 
    border-radius: 20px !important; 
}

/* 3. Fix the Off-Centered Vote Buttons Hover State */
.blyrics-footer__vote {
    background: rgba(255, 255, 255, 0.08) !important; 
    border: 1px solid rgba(255, 255, 255, 0.05) !important; 
    border-radius: 10px !important; 
    transition: all 0.2s ease !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    box-sizing: border-box !important;
    width: 32px !important;
    height: 32px !important;
}

.blyrics-footer__vote:hover {
    background: rgba(255, 255, 255, 0.15) !important; 
    transform: translateY(-2px) !important;
}

.blyrics-footer__vote svg {
    transform: none !important;
    margin: 0 !important;
}

/* 4. The Discord Icon Fix */
/* Aggressively forces the grey icon to bright white without breaking its transparency */
.blyrics-footer__discord svg,
.blyrics-footer__discord img {
    filter: brightness(200%) contrast(200%) grayscale(100%) !important;
    opacity: 1 !important;
}

/* ==========================================================================
   10. PLAYER BAR - Glassmorphism
   ========================================================================== */
ytmusic-player-bar {
  background: var(--ui-color);
  backdrop-filter: blur(var(--ui-blur));
}

#player-bar-background {
  backdrop-filter: none;
}

#layout[player-ui-state="PLAYER_PAGE_OPEN"] ytmusic-player-bar, 
#layout[player-ui-state="PLAYER_PAGE_OPEN"] #player-bar-background {
  background: transparent !important;
}

/* Progress Bar */
#primaryProgress.tp-yt-paper-progress {
  --paper-progress-active-color: var(--accent);
}

#progress-bar[focused],
ytmusic-player-bar:hover #progress-bar {
  --paper-slider-knob-color: var(--accent) !important;
  --paper-slider-knob-start-color: var(--accent) !important;
  --paper-slider-knob-start-border-color: var(--accent) !important;
}

#progress-bar.ytmusic-player-controls {
  --paper-slider-knob-start-color: var(--accent);
  --paper-slider-knob-start-border-color: var(--accent);
  --paper-slider-knob-color: var(--accent);
  --paper-slider-active-color: var(--accent);
}

#hover-time-info.ytmusic-player-bar {
  padding: 12px;
  border-radius: var(--radius-panel);
  background: var(--ui-contrast);
  color: var(--text-primary);
  backdrop-filter: blur(var(--ui-blur));
  border: var(--ui-border);
}

/* Song Info */
.content-info-wrapper.ytmusic-player-bar .byline.ytmusic-player-bar {
  color: var(--accent);
  --yt-endpoint-color: var(--accent);
  --yt-endpoint-visited-color: var(--accent);
  --yt-endpoint-hover-color: var(--accent-highlight);
}

.thumbnail-image-wrapper.ytmusic-player-bar,
.image.ytmusic-player-bar {
  display: block;
  border-radius: var(--radius-art);
}

.time-info.ytmusic-player-bar,
.duration.ytmusic-player-queue-item {
  color: var(--text-secondary);
}

/* Volume Control */
ytmusic-app {
  --ytmusic-player-bar-background: transparent;
  .volume-slider.ytmusic-player-bar,
  .expand-volume-slider.ytmusic-player-bar {
    --paper-slider-knob-color: var(--accent);
    --paper-slider-knob-start-color: var(--accent);
    --paper-slider-knob-start-border-color: var(--accent);
    --paper-slider-container-color: transparent;
  }
}

/* Icons */
.spinner-layer.tp-yt-paper-spinner-lite {
  color: var(--icon);
}

ytmusic-player-bar:not([repeat-mode="NONE"]),
ytmusic-player-controls:not([repeat-mode="NONE"]) {
  .repeat .yt-icon-shape {
    color: var(--accent-icon);
  }
}

ytmusic-player-bar[shuffle-on],
ytmusic-player-controls[shuffle-on] {
  .shuffle yt-icon,
  .expand-shuffle yt-icon {
    color: var(--accent-icon);
  }
}

ytmusic-player-bar:has(.volume-slider[value="0"]) {
  .volume yt-icon,
  .expand-volume yt-icon {
    color: var(--accent-icon);
  }
}

/* Resso-style Play Button */
.play-pause-button-wrapper.ytmusic-player-controls {
  color: transparent;
  background: transparent;
  transform: scale(1.2);
  transition: transform 0.3s ease;
  &:hover {
    transform: scale(1.4);
  }
}

.next-button.ytmusic-player-controls,
.previous-button.ytmusic-player-controls,
.shuffle.ytmusic-player-controls,
.repeat.ytmusic-player-controls {
  color: transparent;
  background: transparent !important;
  transition: transform 0.3s ease;
  &:hover {
    transform: scale(1.2);
  }
}
/* ==========================================================================
   11. NAVIGATION BAR - Glass
   ========================================================================== */
#nav-bar-background.ytmusic-app-layout,
ytmusic-app-layout.content-scrolled #nav-bar-divider {
  opacity: 1;
  backdrop-filter: blur(var(--ui-blur));
  background: var(--ui-color);
  border-bottom: var(--ui-border) !important;
  border-top: 0 !important;
}

ytmusic-app-layout[is-bauhaus-sidenav-enabled].content-scrolled,
ytmusic-app-layout[is-bauhaus-sidenav-enabled][player-page-open] {
  #mini-guide-background.ytmusic-app-layout {
    opacity: 0;
  }
}

/* Drawer */
ytmusic-app[is-bauhaus-sidenav-enabled] #guide-wrapper.ytmusic-app {
  background: var(--ui-color);
  padding: 2px;
  border-right: var(--ui-border);
  backdrop-filter: blur(var(--ui-blur));
}

#layout[player-page-open] {
  #guide-wrapper {
    background: var(--ui-color) !important;
    border-right: var(--ui-border) !important;
  }
  #nav-bar-background {
    background: var(--ui-color) !important;
    border-bottom: var(--ui-border) !important;
  }
}

tp-yt-paper-item.ytmusic-guide-entry-renderer:hover {
  background: var(--ui-highlight);
}

#divider {
  border: 0 !important;
}

/* ==========================================================================
   13. GLASS CARDS - All Components
   ========================================================================== */
ytmusic-player-queue-item,
ytmusic-two-row-item-renderer,
ytmusic-responsive-list-item-renderer,
.ytmusic-shelf-renderer .title,
.ytmusic-carousel {
  background: var(--glass-bg-primary) !important;
  backdrop-filter: blur(16px) saturate(1.5);
  -webkit-backdrop-filter: blur(16px) saturate(1.5);
  border: 1px solid var(--glass-border);
  border-radius: var(--resso-card-radius);
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
  transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
}

ytmusic-player-queue-item:hover,
ytmusic-two-row-item-renderer:hover,
ytmusic-responsive-list-item-renderer:hover {
  background: var(--glass-bg-hover) !important;
  border-color: var(--glass-border-hover);
  transform: translateY(-2px);
  box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3);
}

ytmusic-player-queue-item {
  margin: 0.5rem 0;
  padding: 0.75rem 1rem;
  border-radius: var(--radius-highlight);
}
