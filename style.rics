
/* ═══════════════════════════════════════════════════════════════════════
   APPLE ENHANCEMENTS — Appended to Darky Theme
   ═══════════════════════════════════════════════════════════════════════ */

@font-face {
  font-family: "MySanFrancisco";
  src: url("https://raw.githubusercontent.com/sahibjotsaggu/San-Francisco-Pro-Fonts/refs/heads/master/SF-Pro-Display-Bold.otf") format("opentype");
  font-weight: normal;
  font-style: normal;
}

:root {
  --blyrics-lyric-active-color: color(display-p3 1 1 1 /1);
  --blyrics-lyric-inactive-color: color(display-p3 1 1 1 /0.2);
  --blyrics-font-family: "MySanFrancisco", "SF Pro", system-ui, "Segoe UI",
    Roboto, Helvetica, Arial, sans-serif, "Apple Color Emoji", "Segoe UI Emoji",
    "Segoe UI Symbol";
  --blyrics-lyric-scroll-duration: 400ms;
  --blyrics-lyric-scroll-timing-function: ease-in-out;
  --blyrics-scale-transition-duration: 0.6s;
  --blyrics-scroll-timing-offset: 0.6s;
  --blyrics-background-rotate-speed: 30s;
  --blyrics-fullscreen-panel-size: 55%;
  --ytmusic-background: black;
  --ytmusic-player-bar-background: black;
  --ytmusic-nav-bar-height: 56px;
  --ytmusic-player-bar-height: 64px !important;
}

* {
  font-family: "MySanFrancisco", "SF Pro", system-ui, "Segoe UI",
    Roboto, Helvetica, Arial, sans-serif, "Apple Color Emoji", "Segoe UI Emoji",
    "Segoe UI Symbol" !important;
}

ytmusic-player-page:before {
  background: var(--blyrics-background-img);
  background-position: 50% !important;
  background-repeat: no-repeat;
  background-size: cover;
  bottom: 0;
  content: "";
  filter: saturate(var(--blyrics-background-saturate)) blur(var(--blyrics-background-blur));
  left: 0;
  position: absolute;
  right: 0;
  top: 0;
  transform: scale(1.2);
  z-index: -100;
  animation: none;
  opacity: 0.3;
  /* animation: slowRotate var(--blyrics-background-rotate-speed) linear infinite
      alternate,
    opacityRotate calc(var(--blyrics-background-rotate-speed) / 2) ease-in-out
      infinite alternate; */
}

ytmusic-player-page:not([video-mode])[player-ui-state="FULLSCREEN"]>div>div#side-panel {
  margin: 0 0 0 0 !important;
}

ytmusic-player-page[video-mode][player-ui-state="FULLSCREEN"]>div>div#main-panel {
  max-width: 70%;
}

/* blurs every single line (when not scrolling) to 5px */
.blyrics-container:not([data-sync="none"]):not(.blyrics-user-scrolling)>.blyrics--line {
  filter: blur(9.5px);
  /* sets transition for when it goes active */
  transition: filter 0.5s 0s, opacity 0.5s 0s,
    transform 0.166s var(--blyrics-anim-delay, 0s) !important;
}

/* this looks ugly, no blur is okay */
/* .blyrics-container[data-sync="none"]>.blyrics--line>span>.blyrics--word {
  color: white !important;
} */


.blyrics--line:not([data-agent="v1"]) {
  justify-content: flex-end;
  text-align: right;
  transform-origin: right center !important;
}

/* downwards blurring */

/* 1 line below */
.blyrics-container:not(.blyrics-user-scrolling)>.blyrics--active+.blyrics--line:not(.blyrics--active) {
  filter: blur(2px) !important;
}

/* 2 lines below */
.blyrics-container:not(.blyrics-user-scrolling)>.blyrics--active+.blyrics--line+.blyrics--line {
  filter: blur(3.5px) !important;
}

/* 3 line below */
.blyrics-container:not(.blyrics-user-scrolling)>.blyrics--active+.blyrics--line+.blyrics--line+.blyrics--line {
  filter: blur(5px) !important;
}

/* 4 lines below */
.blyrics-container:not(.blyrics-user-scrolling)>.blyrics--active+.blyrics--line+.blyrics--line+.blyrics--line+.blyrics--line {
  filter: blur(6.5px) !important;
}

/* 5 lines below */
.blyrics-container:not(.blyrics-user-scrolling)>.blyrics--active+.blyrics--line+.blyrics--line+.blyrics--line+.blyrics--line+.blyrics--line {
  filter: blur(8px) !important;
}

/* 6 lines below */
.blyrics-container:not(.blyrics-user-scrolling)>.blyrics--active+.blyrics--line+.blyrics--line+.blyrics--line+.blyrics--line+.blyrics--line+.blyrics--line {
  filter: blur(9.5px) !important;
}

/* past lines (when not scrolling) and when fully finished */
.blyrics-container:not(.blyrics-user-scrolling)>.blyrics--line:has(~ .blyrics--active):not(.blyrics--animating) {
  opacity: 0;
  filter: blur(5px);
  transition: filter 0.25s 0s, opacity 0.9s,
    transform 0.166s var(--blyrics-anim-delay, 0s) !important;
}

/* active line and lines still reading */
.blyrics-container>.blyrics--line.blyrics--active,
.blyrics-container>.blyrics--line.blyrics--animating {
  opacity: 1;
  filter: blur(0px) !important;
}

/* .blyrics-container > .blyrics--line.blyrics--pre-animating {
  /* transform: scale(var(--blyrics-active-scale)); 
  /* transition-delay: calc(var(--blyrics-anim-delay) - (--blyrics-scroll-timing-offset)) !important; 
} */

/* word styling */
.blyrics--line>span>.blyrics--word {
  /* color: var(--blyrics-lyric-inactive-color); */
  /* display: inline-block; */
  /* white-space: pre; */

  /* moves it down for the AM scrolling effect */
  transform: translateY(3px);

  /* sets transform transition */
  /* makes it move up faster and earlier than when it finishes scrolling */
  transition: transform calc(var(--blyrics-duration, 0ms) + 200ms) calc(var(--blyrics-anim-delay, 0.05s) - 0.05s) !important;
}

.blyrics--line>span>.blyrics--word.blyrics--animating {
  transform: translateY(0);
  /* moves it back up when reading */
  animation: none;
  /* disables the bounce transition */
}

/* romanized and translated styling */
.blyrics--line>.blyrics--romanized {
  color: var(--blyrics-lyric-inactive-color);
  font-size: 20px;
  /* removes romanization window */
  padding-block: 0;
  background: none;
  padding: 0;
  border: 0;
}

.blyrics--line>.blyrics--translated {
  color: var(--blyrics-lyric-inactive-color);
  /* removes translation window */
  padding-block: 0;
  background: none;
  padding: 0;
  border: 0;
  font-size: 20px;
}

.blyrics--line[data-romanized="true"]>.blyrics--translated {
  font-size: 16px;
  /* tad bit smaller if romanized */
}

/* when there is no word sync */
.blyrics--word.blyrics-zero-dur-animate {
  /* disables any bounce animations */
  animation: none !important;
  animation-delay: 0s !important;
  /* --blyrics-anim-delay: 0s !important; */
}

.blyrics-container[data-sync="synced"]>.blyrics--line>span>.blyrics--word {
  animation: none;
  transform: translateY(0px) !important;
}
.blyrics-container[data-sync="synced"]>.blyrics--line>span>.blyrics--word {
  transition: color var(--blyrics-lyric-scroll-duration) !important;
}
.blyrics-container[data-sync="synced"]>.blyrics--line:not(.blyrics--active)>span>.blyrics--word {
  color: var(--blyrics-lyric-inactive-color) !important;
  transition: color var(--blyrics-lyric-scroll-duration) !important;
}
.blyrics-container[data-sync="synced"]>.blyrics--line.blyrics--active>span>.blyrics--word {
  color: var(--blyrics-lyric-active-color) !important;
}

.blyrics--word::after {
  /* disable the glow (set the color to like 0% opacity because if its none it just explodes) */
  --blyrics-glow-color: color(display-p3 1 1 1 / 0.0001);
}

.blyrics--word.blyrics-zero-dur-animate::after {
  animation: none !important;
  transition-duration: 0s !important;
}

/* .blyrics-container:has(.blyrics--active) > div:not(.blyrics--active):not(.blyrics--active ~ div) {
  filter: blur(0px);
} */

/* To override this variable, set it again in a more specific selector or later in your CSS file: */
:root {
  --blyrics-font-size: 3rem;
  /* This will override the previous value outside the media query */
  --yt-album-size: 500px;
}

/* Or, inside another media query: */
@media (min-width: 1279px) {
  :root {
    --blyrics-font-size: 5rem;
    /* This will override the previous value for this media query */
  }

  .blyrics-background-lyric {
    font-size: 0.65em;
  }
}

/* music details direction fix */
ytmusic-player-page:not([is-video-truncation-fix-enabled])[player-fullscreened]:not([blyrics-dfs]) #main-panel.ytmusic-player-page {
  flex-direction: column;
}

ytmusic-player[is-mweb-player-page-modernization-enabled]:not([video-mode]) {
  border-radius: 12px;
}

#blyrics-title,
#blyrics-artist {
  font-family: "MySanFrancisco", "SF Pro", system-ui, "Segoe UI", Roboto,
    Helvetica, Arial, sans-serif, "Apple Color Emoji", "Segoe UI Emoji",
    "Segoe UI Symbol";
  font-size: 2rem !important;
}

.song-media-controls.ytmusic-player {
  --ytmusic-player-overlay-gradient: linear-gradient(rgba(0, 0, 0, 0.6) 0%, rgba(0, 0, 0, 0) 10%, rgba(0, 0, 0, 0) 100%) !important;
}

ytmusic-player-page:not([video-mode]) #main-panel.ytmusic-player-page {
  flex-direction: column !important;
  justify-content: center;
  height: auto !important;
}


/* defaults */
#blyrics-song-info {
  --player-song-info-size-px: 600px;
  max-width: var(--player-song-info-size-px);
  width: var(--player-song-info-size-px);
  padding-top: 2rem;
}

ytmusic-player-page:not([video-mode]) {
  display: block !important;
  text-align: left !important;
}

ytmusic-player-page:not([is-mweb-modernization-enabled]):not([blyrics-video-mode]):not([video-mode]) #player.ytmusic-player-page {
  max-height: 400px;
  margin: 0;
}

/* defaults */
ytmusic-player-page:not([is-video-truncation-fix-enabled])[player-fullscreened]:not([blyrics-dfs]):not([video-mode]) #player.ytmusic-player-page {
  --player-square-size-px: 600px;
  max-height: var(--player-square-size-px);
  max-width: var(--player-square-size-px);
  height: var(--player-square-size-px);
  width: var(--player-square-size-px);
  border-radius: 12px;
}

/* descending */
@media (max-width: 1700px) {
  ytmusic-player-page:not([is-video-truncation-fix-enabled])[player-fullscreened]:not([blyrics-dfs]):not([video-mode]) #player.ytmusic-player-page {
    --player-square-size-px: 550px;
  }

  #blyrics-song-info {
    --player-song-info-size-px: 550px;
  }
}

/* descending */
@media (max-width: 1590px) {
  ytmusic-player-page:not([is-video-truncation-fix-enabled])[player-fullscreened]:not([blyrics-dfs]):not([video-mode]) #player.ytmusic-player-page {
    --player-square-size-px: 500px;
  }

  #blyrics-song-info {
    --player-song-info-size-px: 500px;
  }
}

/* descending */
@media (max-width: 1400px) {
  ytmusic-player-page:not([is-video-truncation-fix-enabled])[player-fullscreened]:not([blyrics-dfs]):not([video-mode]) #player.ytmusic-player-page {
    --player-square-size-px: 450px;
  }

  #blyrics-song-info {
    --player-song-info-size-px: 450px;
  }
}

@media (max-width: 1279px) {
  ytmusic-player-page:not([is-video-truncation-fix-enabled])[player-fullscreened]:not([blyrics-dfs]):not([video-mode]) #player.ytmusic-player-page {
    --player-square-size-px: 400px;
  }
  #blyrics-song-info {
    --player-song-info-size-px: 400px;
  }
}

@media (max-width: 1170px) {
  ytmusic-player-page:not([is-video-truncation-fix-enabled])[player-fullscreened]:not([blyrics-dfs]):not([video-mode]) #player.ytmusic-player-page {
    --player-square-size-px: 350px;
  }
  #blyrics-song-info {
    --player-song-info-size-px: 350px;
  }
}

@media (max-width: 1024px) {
  ytmusic-player-page:not([is-video-truncation-fix-enabled])[player-fullscreened]:not([blyrics-dfs]):not([video-mode]) #player.ytmusic-player-page {
    --player-square-size-px: 300px;
  }

  #blyrics-song-info {
    --player-song-info-size-px: 300px;
  }
}

@media (max-width: 768px) {
  ytmusic-player-page:not([is-video-truncation-fix-enabled])[player-fullscreened]:not([blyrics-dfs]):not([video-mode]) #player.ytmusic-player-page {
    --player-square-size-px: 200px;
  }

  #blyrics-song-info {
    --player-song-info-size-px: 200px;
  }
}

/* the long word glow from AM */
.blyrics--word[data-long-word]::after {
  --blyrics-glow-color: color(display-p3 1 1 1 / 1);
}

/* redefine the animation because css sucks */
@keyframes blyrics-glow {
  0% {
    filter: drop-shadow(0 0 1rem var(--blyrics-glow-color));
  }

  100% {
    filter: drop-shadow(0 0 0rem var(--blyrics-glow-color));
  }
}

@keyframes blyrics-wobble {
  0%,
  to {
    transform: none;
  }
}

.autoscroll-resume-button {
  text-align: right;
  border-radius: 6px;
  height: 30px;
  padding: 0 1rem;
  font-size: 14px;
  border: none;
  backdrop-filter: none;
  background: rgba(255, 255, 255, 0.15);
}
.autoscroll-resume-button:hover {
  text-shadow: none;
}

.blyrics-footer__container {
  border-radius: 6px;
}

/* scrollbars */
html {
  scrollbar-color: #45494e33 rgba(0, 0, 0, 0);
}

ytmusic-player[player-ui-state=MINIPLAYER] {
  --ytmusic-mini-player-spacing: 10px !important;
  bottom: calc(100vh + var(--ytmusic-mini-player-spacing));
  right: calc(var(--ytmusic-mini-player-spacing) * 2);
}

/* global button */
.yt-spec-button-shape-next--size-m {
  border-radius: 6px;
}

.yt-spec-button-shape-next--mono.yt-spec-button-shape-next--outline {
  border-color: transparent;
  background: rgba(255, 255, 255, 0.1);
}
.yt-spec-button-shape-next--mono.yt-spec-button-shape-next--outline:hover {
  background: rgba(255, 255, 255, 0.2);
}

/* global dropdown */
tp-yt-paper-listbox.ytmusic-menu-popup-renderer {
  padding: 0;
  border-radius: 6px;
}

.icon.ytmusic-menu-navigation-item-renderer,
.icon.ytmusic-menu-service-item-renderer,
.icon.ytmusic-toggle-menu-service-item-renderer {
  margin: 0 !important;
}

tp-yt-paper-item.ytmusic-menu-service-item-download-renderer {
  padding: 0 10px 0 10px;
}

ytmusic-menu-service-item-renderer {
  padding: 0 10px;
  height: 32px;
  flex-direction: row-reverse;
  justify-content: space-between;
}
ytmusic-menu-service-item-renderer > yt-formatted-string.ytmusic-menu-service-item-renderer {
  margin: 0 !important;
}

ytmusic-toggle-menu-service-item-renderer {
  padding: 0 10px;
  height: 32px;
  flex-direction: row-reverse;
  justify-content: space-between;
}
ytmusic-toggle-menu-service-item-renderer > yt-formatted-string.ytmusic-toggle-menu-service-item-renderer {
  margin: 0 !important;
}

tp-yt-paper-item.ytmusic-menu-service-item-download-renderer {
  padding: 0 10px;
  min-height: 32px !important;
  height: 32px;
  /* flex-direction: row-reverse;
  justify-content: space-between; */
}

.yt-simple-endpoint.ytmusic-menu-navigation-item-renderer {
  padding: 0 10px;
  height: 32px;
  flex-direction: row-reverse;
  justify-content: space-between;
}
.yt-simple-endpoint.ytmusic-menu-navigation-item-renderer > yt-formatted-string.ytmusic-menu-navigation-item-renderer {
  margin: 0;
}

.primary-entry-icon.ytmusic-menu-service-item-download-renderer {
  margin-right: 8px;
}

tp-yt-paper-listbox > ytmusic-menu-navigation-item-renderer:not(:last-child),
tp-yt-paper-listbox > ytmusic-menu-service-item-renderer:not(:last-child),
tp-yt-paper-listbox > ytmusic-toggle-menu-service-item-renderer:not(:last-child),
tp-yt-paper-listbox > ytmusic-menu-service-item-download-renderer:not(:last-child)
{
  border-bottom: 1px solid rgba(255, 255, 255, .1) !important;
}

/* search bar */
.search-container.ytmusic-search-box {
  box-shadow: none !important;
}

ytmusic-search-box[is-bauhaus-sidenav-enabled] { 
  --ytmusic-search-box-height: 36px !important;
}

/* search box default */
ytmusic-search-box[is-bauhaus-sidenav-enabled] .search-box.ytmusic-search-box {
  height: var(--ytmusic-search-box-height);
  border-radius: 6px !important;
}

/* search box - not interacting */
ytmusic-search-box[is-bauhaus-sidenav-enabled]:not([opened]):not([has-query]) .search-box.ytmusic-search-box {
  border-radius: 6px !important;
  height: var(--ytmusic-search-box-height);
}

/* search box opened */
ytmusic-search-box[is-bauhaus-sidenav-enabled][opened] .search-box.ytmusic-search-box {
  border-radius: 6px 6px 0 0 !important;
  background: var(--ytmusic-search-background);
}

/* suggestion list - bottom radius and adjusting position and padding */
ytmusic-search-box[is-bauhaus-sidenav-enabled] #suggestion-list.ytmusic-search-box {
  padding: 0;
  border-radius: 0 0 6px 6px;
  top: 36px;
}

ytmusic-search-suggestion {
  color: rgba(255, 255, 255, 1);
}

/* adjusts margin of first item */
ytmusic-search-suggestion:first-child {
  margin: 0 0 -5px 0;
}

/* this effect makes it look like the item hover background aren't so apart from eachother */
ytmusic-search-suggestion:not(:first-child) {
  margin: -5px 0;
}

/* removes padding from section */
#suggestions.ytmusic-search-suggestions-section {
    padding: 0;
}

/* styling background of the hovered item */
#suggestions.ytmusic-search-suggestions-section>.ytmusic-search-suggestions-section {
  position: relative;
  background-color: transparent !important;
}

#suggestions.ytmusic-search-suggestions-section>.ytmusic-search-suggestions-section::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  width: calc(100% - 1rem);
  height: calc(100% - 1rem);
  margin: 0.5rem;
  background-color: rgba(255, 255, 255, 0);
  border-radius: 6px;
}

#suggestions.ytmusic-search-suggestions-section>.ytmusic-search-suggestions-section:hover::before {
  background-color: rgba(255, 255, 255, .1);
}

ytmusic-search-box[is-bauhaus-sidenav-enabled]:not([opened]):not([has-query]) .search-box.ytmusic-search-box {
  background: rgba(255, 255, 255, .08);
}

/* account */
ytmusic-nav-bar.ytmusic-app > .right-content#right-content {
  padding-right: 0.5rem;
  right: 0 !important;
}

/* cast button */
ytmusic-cast-button {
  display: none;
}

/* controls buttons */
div.left-controls-buttons > yt-icon-button.previous-button,
div.left-controls-buttons > yt-icon-button.next-button {
  opacity: 0.75;
  transition: opacity 0.25s;
}

/* buttons when hovered */
div.left-controls-buttons > yt-icon-button.previous-button:hover,
div.left-controls-buttons > yt-icon-button.play-pause-button:hover,
div.left-controls-buttons > yt-icon-button.next-button:hover {
  background-color: rgba(0,0,0,0);
  opacity: 1;
}

/* progress bar */
ytmusic-player-bar {
  display: flex;
  justify-content: space-between;
}

.left-controls.ytmusic-player-bar {
  flex-direction: column;
  justify-content: center;
}
.time-info.ytmusic-player-bar {
  margin: 0;
  position: absolute;
  bottom: 3px;
}
.left-controls-buttons.ytmusic-player-bar {
  transform: scale(0.8);
}

#primaryProgress.tp-yt-paper-progress {
  background: white;
  border-radius: 100px;
}
ytmusic-player-bar:hover #progress-bar.ytmusic-player-bar {
  --paper-slider-knob-color: white;
  --paper-slider-knob-start-color: white;
  --paper-slider-knob-start-border-color: white;
}

#progressContainer.tp-yt-paper-progress {
  --paper-progress-height: 3px;
}

#secondaryProgress.tp-yt-paper-progress {
  border-radius: 2px;
}

#hover-time-info.ytmusic-player-bar {
  background-color: rgba(0, 0, 0, .25);
  border: 1px solid rgba(255, 255, 255, .15);
  border-radius: 6px;
  padding: 4px 7px;
}

.menu.ytmusic-player-bar {
  margin: 0 0 0 -11px;
  /* now you see it's very precisely 11 px for visual alignment of space */
}

ytmusic-like-button-renderer {
  display: flex;
  flex-direction: row-reverse;
}

.dislike.ytmusic-like-button-renderer {
  margin-right: 0;
}
.like.ytmusic-like-button-renderer {
  margin-right: -5px;
}

.middle-controls.ytmusic-player-bar {
  height: calc(var(--ytmusic-player-bar-height) - 1.7rem);
  /* background: #4d4d4d80; */
  background: rgba(255, 255, 255, 0.1);
  border-radius: 4px;
  transform: translateY(1.5px); /* visual alignment */
}
.middle-controls.ytmusic-player-bar > .thumbnail-image-wrapper.ytmusic-player-bar {
  height: calc(var(--ytmusic-player-bar-height) - 1.7rem);
}
.middle-controls.ytmusic-player-bar > .thumbnail-image-wrapper.ytmusic-player-bar > img {
  height: calc(var(--ytmusic-player-bar-height) - 1.7rem);
}
.middle-controls-buttons.ytmusic-player-bar {
  padding-left: 1.1rem;
}

.content-info-wrapper.ytmusic-player-bar {
  align-items: center;
}

ytmusic-player-bar {
  align-items: center;
}

/* sidebar */

ytmusic-nav-bar[is-bauhaus-sidenav-enabled] .left-content.ytmusic-nav-bar {
  padding-left: 1.5rem;
}

ytmusic-nav-bar[is-bauhaus-sidenav-enabled]:not([guide-collapsed]) .left-content.ytmusic-nav-bar {
  padding-left: calc(1.5rem + 5px);
}

ytmusic-guide-renderer:not([is-collapsed]) {
  padding-left: 1.5rem;
  padding-right: 1.5rem;
}

tp-yt-paper-item.ytmusic-guide-entry-renderer {
  border-radius: 6px;
  // padding: 6px 6px !important;
  min-height: 18px;
}

#items > ytmusic-guide-entry-renderer.ytmusic-guide-section-renderer {
  // max-height: 30px;
  // height: 30px;
}
#items > ytmusic-guide-entry-renderer.ytmusic-guide-section-renderer > tp-yt-paper-item {
  padding: 3px !important;
}
#items > ytmusic-guide-entry-renderer.ytmusic-guide-section-renderer > tp-yt-paper-item yt-formatted-string {
  font-size: 14px;
}

ytmusic-guide-section-renderer.ytmusic-guide-renderer #divider {
  display: none;
}

/* playlists section */

ytmusic-guide-section-renderer:not([is-primary]) > #items > ytmusic-guide-entry-renderer > tp-yt-paper-item.ytmusic-guide-entry-renderer > .title-column {
  // background: #000;
  display: flex;

  align-items: center;
  flex-basis: content;
  flex-direction: row-reverse;
}

/* disable table-like behaviour */
ytmusic-guide-section-renderer:not([is-primary]) > #items > ytmusic-guide-entry-renderer > tp-yt-paper-item.ytmusic-guide-entry-renderer > .title-column > .title-group {
  width: 100%;
}

/* disable artist */
ytmusic-guide-section-renderer:not([is-primary]) > #items > ytmusic-guide-entry-renderer > tp-yt-paper-item.ytmusic-guide-entry-renderer > .title-column > .subtitle-group > yt-formatted-string {
  display: none;
}

ytmusic-guide-section-renderer[is-primary]>div#items>
ytmusic-guide-entry-renderer.ytmusic-guide-section-renderer>
tp-yt-paper-item.ytmusic-guide-entry-renderer:not([aria-current=true]):hover {
  background-color: rgba(0,0,0,0) !important;
}

ytmusic-guide-section-renderer > #buttons.ytmusic-guide-section-renderer {
  padding-top: 2rem;
  padding-left: 0;
  padding-right: 0;
  position: relative;
}

ytmusic-guide-section-renderer:nth-child(2) > #buttons.ytmusic-guide-section-renderer::before {
  position: absolute;
  content: 'Playlists';
  left: 0;
  font-size: 13px;
  line-height: 30px;
}

/* disable New Playlist text in btn */
ytmusic-guide-section-renderer:nth-child(2) > #buttons.ytmusic-guide-section-renderer >
yt-button-renderer.ytmusic-guide-section-renderer > yt-button-shape > 
button > .yt-spec-button-shape-next__button-text-content {
  display: none;
}

/* set plus icon margin to 0 */
ytmusic-guide-section-renderer:nth-child(2) > #buttons.ytmusic-guide-section-renderer >
yt-button-renderer.ytmusic-guide-section-renderer > yt-button-shape > 
button > .yt-spec-button-shape-next__icon {
  margin: 0 !important;
}

ytmusic-guide-section-renderer:nth-child(2) > #buttons.ytmusic-guide-section-renderer >
yt-button-renderer.ytmusic-guide-section-renderer > yt-button-shape > 
button {
  max-height: 30px !important;
  height: 30px !important;
  max-width: 30px !important;
  width: 30px !important;
  background: transparent !important;
}

ytmusic-guide-section-renderer:nth-child(2) > #buttons.ytmusic-guide-section-renderer >
yt-button-renderer.ytmusic-guide-section-renderer {
  position: absolute;
  right: 0;
  width: auto !important;
}

/* move playlists a bit down */
ytmusic-guide-section-renderer:nth-child(2) > #items.ytmusic-guide-section-renderer {
  padding-top: 1rem;
}

ytmusic-guide-section-renderer:nth-child(2) > #items.ytmusic-guide-section-renderer >
ytmusic-guide-entry-renderer.ytmusic-guide-section-renderer >
tp-yt-paper-item.ytmusic-guide-entry-renderer {
  height: 24px;
  padding-left: 3.9rem !important;
  // 3.9 very specific for alignment
  // Fuck css. I am serious. Why does the padding affect the height value given.
  // BULLLSHIIIIITTTT!!!
}

ytmusic-guide-section-renderer:nth-child(2) > #items.ytmusic-guide-section-renderer >
ytmusic-guide-entry-renderer.ytmusic-guide-section-renderer >
tp-yt-paper-item.ytmusic-guide-entry-renderer:hover {
  background: transparent !important;
}

/* disable play button - TODO? */
ytmusic-guide-section-renderer:nth-child(2) > #items.ytmusic-guide-section-renderer >
ytmusic-guide-entry-renderer.ytmusic-guide-section-renderer >
tp-yt-paper-item.ytmusic-guide-entry-renderer > ytmusic-play-button-renderer {
  display: none;
}

/* podcast cards with small play btn */
ytmusic-play-button-renderer[size=MUSIC_PLAY_BUTTON_SIZE_HUGE]:hover .content-wrapper.ytmusic-play-button-renderer,
ytmusic-play-button-renderer[size=MUSIC_PLAY_BUTTON_SIZE_MEDIUM]:hover .content-wrapper.ytmusic-play-button-renderer
{
  transform: scale(1) !important;
  background: #fa586a !important;
}

/* album art cards with big play btn */
/* disable that big black box */
ytmusic-item-thumbnail-overlay-renderer:hover #background.ytmusic-item-thumbnail-overlay-renderer {
  opacity: 000.1;
}

/* position play button via flex */
.ytmusic-carousel > a > ytmusic-item-thumbnail-overlay-renderer[content-position=MUSIC_ITEM_THUMBNAIL_OVERLAY_CONTENT_POSITION_CENTERED] > #content.ytmusic-item-thumbnail-overlay-renderer {
  align-items: end;
  justify-content: right;
  margin-right: 1rem;
  margin-bottom: 1rem;
}

ytmusic-item-thumbnail-overlay-renderer[content-position=MUSIC_ITEM_THUMBNAIL_OVERLAY_CONTENT_POSITION_CENTERED] #content.ytmusic-item-thumbnail-overlay-renderer:not(:hover) >
ytmusic-play-button-renderer[size=MUSIC_PLAY_BUTTON_SIZE_HUGE]
{
  opacity: 0;
}

ytmusic-item-thumbnail-overlay-renderer[content-position=MUSIC_ITEM_THUMBNAIL_OVERLAY_CONTENT_POSITION_CENTERED] #content.ytmusic-item-thumbnail-overlay-renderer:hover >
ytmusic-play-button-renderer[size=MUSIC_PLAY_BUTTON_SIZE_HUGE] > .content-wrapper.ytmusic-play-button-renderer
{
  background: rgba(0,0,0,.25);
}

/* set background opacity on hover */
ytmusic-item-thumbnail-overlay-renderer:hover #background.ytmusic-item-thumbnail-overlay-renderer {
  opacity: 0.5 !important;
}

/* revert play button sizes */
ytmusic-play-button-renderer[size=MUSIC_PLAY_BUTTON_SIZE_HUGE] {
  --ytmusic-play-button-size: 40px !important;
  --ytmusic-play-button-icon-size: 24px !important;
}

/* menu btn pos */
ytmusic-item-thumbnail-overlay-renderer>:not(.ytmusic-item-thumbnail-overlay-renderer) {
  top: 1rem;
  right: 1rem;
  /* couldnt find a way to move it without breaking some overlap things */
}

.yt-spec-button-shape-next--size-m.yt-spec-button-shape-next--icon-button {
  width: 40px;
  height: 40px;
  border-radius: 50%;
}

ytmusic-item-thumbnail-overlay-renderer:hover > ytmusic-menu-renderer.ytmusic-two-row-item-renderer > yt-button-shape > button {
  background: rgba(0, 0, 0, 0.25) !important;
}
ytmusic-item-thumbnail-overlay-renderer:hover > ytmusic-menu-renderer.ytmusic-two-row-item-renderer > yt-button-shape > button:hover {
  background: #fa586a !important;
}

/* quick picks menu etc , carousels in general */
ytmusic-responsive-list-item-renderer.ytmusic-carousel >
ytmusic-menu-renderer.ytmusic-responsive-list-item-renderer {
  flex-basis: auto !important;
  overflow: initial !important;
}

/* makes menu btn always visible */
ytmusic-responsive-list-item-renderer.ytmusic-carousel >
ytmusic-menu-renderer.ytmusic-responsive-list-item-renderer > 
#button-shape.ytmusic-menu-renderer {
  opacity: 1 !important;
  transform: rotate(90deg);
}

/* change dots colour */
ytmusic-responsive-list-item-renderer.ytmusic-carousel >
ytmusic-menu-renderer.ytmusic-responsive-list-item-renderer > 
#button-shape.ytmusic-menu-renderer >
button > div.yt-spec-button-shape-next__icon > span.ytIconWrapperHost >
span.yt-icon-shape.ytSpecIconShapeHost > div {
  /* fill: #fa586a !important; */
  /* MODIFY THIS ^^^ */
}

/* disable like and dislike buttons */
ytmusic-responsive-list-item-renderer.ytmusic-carousel >
ytmusic-menu-renderer.ytmusic-responsive-list-item-renderer > 
div#top-level-buttons {
  display: none;
}

/* chips */
ytmusic-chip-cloud-chip-renderer > div > a.ytmusic-chip-cloud-chip-renderer {
  border-radius: 6px !important;
}

ytmusic-chip-cloud-chip-renderer:not(:last-child) a.ytmusic-chip-cloud-chip-renderer {
  border-top-right-radius: 3px !important;
  border-bottom-right-radius: 3px !important;
}
ytmusic-chip-cloud-chip-renderer:not(:first-child) a.ytmusic-chip-cloud-chip-renderer {
  border-top-left-radius: 3px !important;
  border-bottom-left-radius: 3px !important;
}
ytmusic-chip-cloud-chip-renderer {
  margin-left: 2px !important;
  margin-right: 2px !important;
  padding-bottom: 0 !important;
}

/* library */
#start-items.ytmusic-side-aligned-item-renderer>*.ytmusic-side-aligned-item-renderer {
  margin: 0 10px 0 0 !important;
}

/* profile items */
ytmusic-two-row-item-renderer[has-circle-cropped-thumbnail] .details.ytmusic-two-row-item-renderer {
  text-align: start;
}

ytmusic-two-row-item-renderer[has-circle-cropped-thumbnail] >
.details.ytmusic-two-row-item-renderer >
div > .title.ytmusic-two-row-item-renderer {
  text-align: start;
}

/* carousel titles */
.button-group.ytmusic-carousel-shelf-renderer {
  gap: 4px;
}

/* .button-group.ytmusic-carousel-shelf-renderer > 
yt-icon-button#previous-items-button {
  border-top-right-radius: 6px;
  border-bottom-right-radius: 6px;
}
.button-group.ytmusic-carousel-shelf-renderer > 
yt-icon-button#next-items-button {
  border-top-left-radius: 6px;
  border-bottom-left-radius: 6px;
} */

.header-group.ytmusic-carousel-shelf-renderer {
  gap: 1rem;
}

yt-icon-button.ytmusic-carousel-shelf-renderer {
  padding: 8px 0;
  width: auto;
  border-radius: 6px;
  border: 0;
}

yt-icon-button.ytmusic-carousel-shelf-renderer[disabled] {
  border: none;
}

/* player */
/* tp-yt-paper-tab.iron-selected.ytmusic-player-page {
  padding: 2px 12px 0 12px;
} */
tp-yt-paper-tabs.ytmusic-player-page {
  border-bottom: none;
}

#tabsContainer.tp-yt-paper-tabs {
  position: static;
}

.tabs-content.tp-yt-paper-tabs {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 8px;
  height: 30px;
  position: absolute;
  right: 2rem;
  bottom: 2rem;
  z-index: 999;
  backdrop-filter: blur(4px);
}

tp-yt-paper-tab.iron-selected.ytmusic-player-page {
  position: relative;
}

tp-yt-paper-tab.iron-selected.ytmusic-player-page::before {
  position: absolute;
  content: '';
  width: 100%;
  height: 100%;
  top: 0;
  left: 0;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 6px;
}

tp-yt-paper-tab.ytmusic-player-page {
  width: 30px;
  padding: 0 !important;
}

tp-yt-paper-tab.ytmusic-player-page > .tab-content {
  display: none;
}

// 

tp-yt-paper-tab.ytmusic-player-page::after {
  content: '';
  width: 22px;
  height: 22px;
  top: 0;
  left: 0;
}

tp-yt-paper-tab:nth-child(2).ytmusic-player-page::after {
  width: 18px;
  height: 18px;
  scale: 1.3;
  background: url('data:image/svg+xml;base64,');
}

tp-yt-paper-tab:nth-child(3).ytmusic-player-page::after {
  background: url('data:image/svg+xml;base64,');
}
tp-yt-paper-tab:nth-child(3).ytmusic-player-page[aria-selected="true"]::after {
  background: url('data:image/svg+xml;base64,');
}

tp-yt-paper-tab:nth-child(4).ytmusic-player-page::after {
  background: url('data:image/svg+xml;base64,');
}
// data:image/svg+xml;base64,

.selection-bar.tp-yt-paper-tabs {
  visibility: hidden;
}

ytmusic-player-page tp-yt-paper-tabs .tp-yt-paper-tabs[style-target=content] {
  text-transform: none;
}

/* icons */

yt-icon.ytmusic-guide-entry-renderer {
  margin-right: 12px;
}

/* sidebar - home */
#items > ytmusic-guide-entry-renderer:nth-child(1) > tp-yt-paper-item > yt-icon > span > div::before {
  content: '';
  width: 100%;
  height: 100%;
  background: url('data:image/svg+xml;base64,');
  position: absolute;
  top: 0;
  left: 0;
  transform: scale(1);
}
#items > ytmusic-guide-entry-renderer:nth-child(1) > tp-yt-paper-item > yt-icon > span > div > svg {
  visibility: hidden;
}

/* sidebar - explore */
#items > ytmusic-guide-entry-renderer:nth-child(2) > tp-yt-paper-item > yt-icon > span > div::before {
  content: '';
  width: 100%;
  height: 100%;
  background: url('data:image/svg+xml;base64,');
  position: absolute;
  top: 0;
  left: 0;
  transform: scale(1);
}
#items > ytmusic-guide-entry-renderer:nth-child(2) > tp-yt-paper-item > yt-icon > span > div > svg {
  visibility: hidden;
}

/* sidebar - library */
#items > ytmusic-guide-entry-renderer:nth-child(3) > tp-yt-paper-item > yt-icon > span > div::before {
  content: '';
  width: 100%;
  height: 100%;
  background: url('data:image/svg+xml;base64,');
  position: absolute;
  top: 0;
  left: 0;
  transform: scale(1);
}
#items > ytmusic-guide-entry-renderer:nth-child(3) > tp-yt-paper-item > yt-icon > span > div > svg {
  visibility: hidden;
}

/* sidebar - playlist icon */
ytmusic-guide-section-renderer:nth-child(2) > #items.ytmusic-guide-section-renderer >
ytmusic-guide-entry-renderer.ytmusic-guide-section-renderer >
tp-yt-paper-item.ytmusic-guide-entry-renderer::before{
  content: '';
  width: 24px;
  height: 24px;
  position: absolute;
  left: 3px;
  background: url('data:image/svg+xml;base64,');
}

/* player bar - next */
yt-icon-button.ytmusic-player-bar.next-button > #button > yt-icon > span > div::before {
  content: '';
  width: 32px;
  height: 28px;
  background: url('data:image/svg+xml;base64,');
  position: absolute;
  top: -2px;
  left: -5px;
  transform: scale(1.4);
}
yt-icon-button.ytmusic-player-bar.next-button > #button > yt-icon > span > div > svg {
  visibility: hidden;
}

/* player bar - prev */
yt-icon-button.ytmusic-player-bar.previous-button > #button > yt-icon > span > div::before {
  content: '';
  width: 32px;
  height: 28px;
  background: url('data:image/svg+xml;base64,');
  position: absolute;
  top: -2px;
  right: -5px;
  transform: scale(1.4) rotate(-180deg);
}
yt-icon-button.ytmusic-player-bar.previous-button > #button > yt-icon > span > div > svg {
  visibility: hidden;
}

.content-container.ytmusic-immersive-header-renderer {
  display: flex;
  justify-content: left;
  flex-direction: row-reverse;
  align-items: center;
  position: relative;
}

/* artist header */

.image.ytmusic-immersive-header-renderer {
  height: 600px;
}

.content-container-wrapper.style-scope.ytmusic-immersive-header-renderer {
  padding-top: 400px !important;
}
.content-container-wrapper.style-scope.ytmusic-immersive-header-renderer >
.gradient-container.style-scope.ytmusic-immersive-header-renderer {
  // background: linear-gradient(1turn,var(--ytmusic-background) 50%,rgba(0,0,0,0) 100%);
  background: none;
}

ytmusic-fullbleed-thumbnail-renderer[thumbnail-scale=MUSIC_THUMBNAIL_SCALE_ASPECT_FILL] .image.ytmusic-fullbleed-thumbnail-renderer {
  object-position: center;
}

#content.ytmusic-app {
  background: black;
}

.image.ytmusic-immersive-header-renderer~.content-container-wrapper.ytmusic-immersive-header-renderer {
  background-color: rgba(0, 0, 0, 0);
}

.content-container.ytmusic-immersive-header-renderer >
.actions.ytmusic-immersive-header-renderer >
.buttons.ytmusic-immersive-header-renderer >
.play-buttons.ytmusic-immersive-header-renderer >
.play-button.style-scope.ytmusic-immersive-header-renderer .yt-spec-button-shape-next__button-text-content span,
.content-container.ytmusic-immersive-header-renderer >
.actions.ytmusic-immersive-header-renderer >
.buttons.ytmusic-immersive-header-renderer >
.play-buttons.ytmusic-immersive-header-renderer >
.radio-button {
  display: none;
}

.content-container.ytmusic-immersive-header-renderer >
.actions.ytmusic-immersive-header-renderer >
.buttons.ytmusic-immersive-header-renderer >
.play-buttons.ytmusic-immersive-header-renderer >
.play-button.style-scope.ytmusic-immersive-header-renderer .yt-spec-button-shape-next__icon {
  margin: 0;
}

.content-container.ytmusic-immersive-header-renderer >
.actions.ytmusic-immersive-header-renderer >
.buttons.ytmusic-immersive-header-renderer >
.play-buttons.ytmusic-immersive-header-renderer >
.play-button.style-scope.ytmusic-immersive-header-renderer {
  min-width: 0;
}

.content-container.ytmusic-immersive-header-renderer >
.actions.ytmusic-immersive-header-renderer >
.buttons.ytmusic-immersive-header-renderer >
.play-buttons.ytmusic-immersive-header-renderer >
.play-button.style-scope.ytmusic-immersive-header-renderer >
yt-button-shape > button.yt-spec-button-shape-next {
  width: 36px;
  height: 36px;
  border-radius: 999px;
  background: #fa586a !important;
  color: white;
  scale: 0.95;
}

.content-container.ytmusic-immersive-header-renderer >
.actions.ytmusic-immersive-header-renderer >
.buttons.ytmusic-immersive-header-renderer >
.play-buttons.ytmusic-immersive-header-renderer >
.play-button.style-scope.ytmusic-immersive-header-renderer >
yt-button-shape > button > div.yt-spec-button-shape-next__icon >
span > span > div {
  background-image: url('data:image/svg+xml;base64,');
}

.content-container.ytmusic-immersive-header-renderer >
.actions.ytmusic-immersive-header-renderer >
.buttons.ytmusic-immersive-header-renderer >
.play-buttons.ytmusic-immersive-header-renderer >
.play-button.style-scope.ytmusic-immersive-header-renderer >
yt-button-shape > button > div.yt-spec-button-shape-next__icon >
span > span > div > svg {
  visibility: hidden;
}

.content-container.ytmusic-immersive-header-renderer >
.actions.ytmusic-immersive-header-renderer >
.buttons.ytmusic-immersive-header-renderer > 
ytmusic-subscribe-button-renderer.subscribe.style-scope {
  position: absolute;
  right: calc(40px + 1rem);
  margin: 0;
}

.content-container.ytmusic-immersive-header-renderer >
.actions.ytmusic-immersive-header-renderer >
.buttons.ytmusic-immersive-header-renderer > 
ytmusic-subscribe-button-renderer.subscribe.style-scope >
yt-button-shape > button {
  border-radius: 999px;
}

.content-container.ytmusic-immersive-header-renderer > 
.subtitle-container {
  position: absolute;
  top: -.5rem;
}

.content-container.ytmusic-immersive-header-renderer > 
.description-container {
  position: absolute;
  right: 0;
  text-align: right;
  bottom: 3rem;
}

ytmusic-immersive-header-renderer:not([is-description-expanded]) .description-container {
  max-width: 50%;
}
ytmusic-immersive-header-renderer[is-description-expanded] .description-container >
yt-formatted-string#description {
  text-align: justify !important;
}

.content-container.ytmusic-immersive-header-renderer > 
h1 > yt-formatted-string {
  margin: 0;
}

ytmusic-menu-renderer.style-scope.ytmusic-immersive-header-renderer {
  position: absolute;
  right: 0;
}

ytmusic-menu-renderer.style-scope.ytmusic-immersive-header-renderer >
yt-button-shape > button {
  background: rgba(255, 255, 255, 0.15);
}

/* artist page */
/* change the layout to a "grid" */
ytmusic-section-list-renderer[main-page-type=MUSIC_PAGE_TYPE_ARTIST] > 
#contents.ytmusic-section-list-renderer >
ytmusic-shelf-renderer.ytmusic-section-list-renderer:nth-child(1) >
#contents.ytmusic-shelf-renderer
{
  display: flex;
  flex-wrap: wrap;
  gap: 0 1rem;
}

ytmusic-section-list-renderer[main-page-type=MUSIC_PAGE_TYPE_ARTIST] > 
#contents.ytmusic-section-list-renderer >
ytmusic-shelf-renderer.ytmusic-section-list-renderer >
.more-button
{
  display: none;
}

/* make them 48% so they DO WRAP */
ytmusic-section-list-renderer[main-page-type=MUSIC_PAGE_TYPE_ARTIST] > 
#contents.ytmusic-section-list-renderer >
ytmusic-shelf-renderer.ytmusic-section-list-renderer:nth-child(1) >
#contents.ytmusic-shelf-renderer > 
ytmusic-responsive-list-item-renderer
{
  width: calc(50% - 1rem);
  border-bottom: none;
  border-top: 1px solid rgba(255, 255, 255, .1);
  padding: 0;
}

/* disable the fifth one */
ytmusic-section-list-renderer[main-page-type=MUSIC_PAGE_TYPE_ARTIST] > 
#contents.ytmusic-section-list-renderer >
ytmusic-shelf-renderer.ytmusic-section-list-renderer:nth-child(1) >
#contents.ytmusic-shelf-renderer > 
ytmusic-responsive-list-item-renderer:nth-child(5)
{
  display: none;
}

/* make thumbnail not be so spaced */
ytmusic-section-list-renderer[main-page-type=MUSIC_PAGE_TYPE_ARTIST] > 
#contents.ytmusic-section-list-renderer >
ytmusic-shelf-renderer.ytmusic-section-list-renderer:nth-child(1) >
#contents.ytmusic-shelf-renderer > 
ytmusic-responsive-list-item-renderer >
.left-items
{
  margin-right: 1rem;
}

/* make them not flex so the things can go below */
ytmusic-section-list-renderer[main-page-type=MUSIC_PAGE_TYPE_ARTIST] > 
#contents.ytmusic-section-list-renderer >
ytmusic-shelf-renderer.ytmusic-section-list-renderer:nth-child(1) >
#contents.ytmusic-shelf-renderer > 
ytmusic-responsive-list-item-renderer >
.flex-columns.ytmusic-responsive-list-item-renderer
{
  display: block;
}

/* remove the spacing between the explicit badge and song title */
ytmusic-section-list-renderer[main-page-type=MUSIC_PAGE_TYPE_ARTIST] > 
#contents.ytmusic-section-list-renderer >
ytmusic-shelf-renderer.ytmusic-section-list-renderer:nth-child(1) >
#contents.ytmusic-shelf-renderer > 
ytmusic-responsive-list-item-renderer >
.flex-columns.ytmusic-responsive-list-item-renderer >
.title-column
{
  justify-content: left;
}

/* remove the spacing between the explicit badge and song title */
ytmusic-section-list-renderer[main-page-type=MUSIC_PAGE_TYPE_ARTIST] > 
#contents.ytmusic-section-list-renderer >
ytmusic-shelf-renderer.ytmusic-section-list-renderer:nth-child(1) >
#contents.ytmusic-shelf-renderer > 
ytmusic-responsive-list-item-renderer >
.flex-columns.ytmusic-responsive-list-item-renderer >
#stacked-layout-badges.badges
{
  position: absolute;
  top: 1rem;
  right: 0;
}

/* remove excessive margin of explicit badge */
ytmusic-section-list-renderer[main-page-type=MUSIC_PAGE_TYPE_ARTIST] > 
#contents.ytmusic-section-list-renderer >
ytmusic-shelf-renderer.ytmusic-section-list-renderer:nth-child(1) >
#contents.ytmusic-shelf-renderer > 
ytmusic-responsive-list-item-renderer >
.flex-columns.ytmusic-responsive-list-item-renderer >
.title-column > #columnar-layout-badges.badges > ytmusic-inline-badge-renderer
{
  margin-left: 4px;
}

/* reverse the items in direction */
ytmusic-section-list-renderer[main-page-type=MUSIC_PAGE_TYPE_ARTIST] > 
#contents.ytmusic-section-list-renderer >
ytmusic-shelf-renderer.ytmusic-section-list-renderer:nth-child(1) >
#contents.ytmusic-shelf-renderer > 
ytmusic-responsive-list-item-renderer >
.flex-columns.ytmusic-responsive-list-item-renderer >
.secondary-flex-columns.ytmusic-responsive-list-item-renderer
{
  flex-direction: row-reverse;
  justify-content: left;
  gap: .5rem;
}

/* delete the artist */
ytmusic-section-list-renderer[main-page-type=MUSIC_PAGE_TYPE_ARTIST] > 
#contents.ytmusic-section-list-renderer >
ytmusic-shelf-renderer.ytmusic-section-list-renderer:nth-child(1) >
#contents.ytmusic-shelf-renderer > 
ytmusic-responsive-list-item-renderer >
.flex-columns.ytmusic-responsive-list-item-renderer >
.secondary-flex-columns.ytmusic-responsive-list-item-renderer >
yt-formatted-string:nth-child(1)
{
  display: none;
}

ytmusic-section-list-renderer[main-page-type=MUSIC_PAGE_TYPE_ARTIST] > 
#contents.ytmusic-section-list-renderer >
ytmusic-shelf-renderer.ytmusic-section-list-renderer:nth-child(1) >
#contents.ytmusic-shelf-renderer > 
ytmusic-responsive-list-item-renderer >
.flex-columns.ytmusic-responsive-list-item-renderer >
.secondary-flex-columns.ytmusic-responsive-list-item-renderer >
yt-formatted-string:nth-child(2)::before
{
  content: '·';
  margin-right: .5rem;
}

/* remove the margin */
ytmusic-section-list-renderer[main-page-type=MUSIC_PAGE_TYPE_ARTIST] > 
#contents.ytmusic-section-list-renderer >
ytmusic-shelf-renderer.ytmusic-section-list-renderer:nth-child(1) >
#contents.ytmusic-shelf-renderer > 
ytmusic-responsive-list-item-renderer >
.flex-columns.ytmusic-responsive-list-item-renderer >
.secondary-flex-columns.ytmusic-responsive-list-item-renderer >
yt-formatted-string
{
  margin-left: 0;
  flex: none;
}

ytmusic-section-list-renderer[main-page-type=MUSIC_PAGE_TYPE_ARTIST] > 
#contents.ytmusic-section-list-renderer >
ytmusic-shelf-renderer.ytmusic-section-list-renderer:nth-child(1) >
#contents.ytmusic-shelf-renderer > 
ytmusic-responsive-list-item-renderer >
.flex-columns.ytmusic-responsive-list-item-renderer >
.secondary-flex-columns.ytmusic-responsive-list-item-renderer >
yt-formatted-string::before
{
